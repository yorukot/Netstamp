# Netstamp self-host settings.
#
# Quickstart can run as-is on localhost. Before exposing Netstamp publicly:
# - change every "change-me" value
# - set APP_ENV=production
# - set BACKEND_BASE_URL to the public origin, for example https://netstamp.example.com
# - pin NETSTAMP_VERSION to a release tag
# - run Netstamp behind HTTPS

DATABASE_PASSWORD=change-me
AUTH_SESSION_HASH_KEY=change-me
AUTH_API_TOKEN_HASH_KEY=change-me-too
