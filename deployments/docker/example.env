# Netstamp self-host defaults.
#
# Quickstart can run as-is on localhost. Before exposing Netstamp publicly,
# change every "change-me" value and set APP_ENV=production behind HTTPS.

NETSTAMP_IMAGE=yorukot/netstamp
NETSTAMP_VERSION=latest
NETSTAMP_PORT=3000

APP_ENV=local
BACKEND_BASE_URL=
HTTP_TRUSTED_PROXIES=

DATABASE_PASSWORD=netstamp
AUTH_JWT_SECRET=change-me
LOG_PSEUDONYM_KEY=change-me

LOG_LEVEL=info
API_VERSION=v1
