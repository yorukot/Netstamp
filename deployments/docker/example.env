# Netstamp self-host settings.
#
# Quickstart can run as-is on localhost. Before exposing Netstamp publicly:
# - replace every "change-me" value with a different random secret
# - set APP_ENV=production
# - set the two public origins
# - pin both image versions to tested tags or digests
# - run Netstamp behind HTTPS

# Images and host port
NETSTAMP_IMAGE=yorukot/netstamp
NETSTAMP_VERSION=latest
TIMESCALEDB_IMAGE=timescale/timescaledb:latest-pg16
NETSTAMP_PORT=3000

# Runtime identity and logging
APP_ENV=local
DEMO_MODE=false
SERVICE_NAME=controller
API_VERSION=v1
LOG_LEVEL=info
LOG_PSEUDONYM_KEY=change-me-log-pseudonym
SYSTEM_SETTINGS_ENCRYPTION_KEY=change-me-settings-encryption
SHUTDOWN_TIMEOUT=10s

# Public origins and HTTP behavior
BACKEND_BASE_URL=
PUBLIC_WEB_BASE_URL=
REQUEST_TIMEOUT=10s
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_TRUSTED_PROXIES=

# Database and connection pool
DATABASE_PASSWORD=change-me-database
DB_MAX_CONNS=10
DB_MIN_CONNS=0
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m

# Sessions, API tokens, registration, and password hashing
AUTH_SESSION_HASH_KEY=change-me-session-hash
AUTH_API_TOKEN_HASH_KEY=change-me-api-token-hash
AUTH_SESSION_IDLE_TTL=24h
AUTH_SESSION_ABSOLUTE_TTL=168h
AUTH_SESSION_TOUCH_INTERVAL=5m
AUTH_SUDO_TTL=5m
AUTH_REGISTRATION_ENABLED=true
AUTH_EXTERNAL_FLOW_TTL=10m
AUTH_PASSWORD_RESET_TOKEN_TTL=30m
AUTH_PASSWORD_RESET_RATE_LIMIT_WINDOW=1h
AUTH_PASSWORD_RESET_IP_LIMIT=10
AUTH_PASSWORD_RESET_EMAIL_LIMIT=3
AUTH_ARGON2ID_MEMORY_KIB=65536
AUTH_ARGON2ID_ITERATIONS=3
AUTH_ARGON2ID_PARALLELISM=4

# Generic OIDC
AUTH_OIDC_ENABLED=false
AUTH_OIDC_ISSUER_URL=
AUTH_OIDC_CLIENT_ID=
AUTH_OIDC_CLIENT_SECRET=
AUTH_OIDC_DISPLAY_NAME=Single sign-on
AUTH_OIDC_JIT_PROVISIONING_ENABLED=false

# Google
AUTH_GOOGLE_ENABLED=false
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GOOGLE_DISPLAY_NAME=Google
AUTH_GOOGLE_JIT_PROVISIONING_ENABLED=false
AUTH_GOOGLE_ALLOWED_HOSTED_DOMAINS=

# GitHub
AUTH_GITHUB_ENABLED=false
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=
AUTH_GITHUB_DISPLAY_NAME=GitHub
AUTH_GITHUB_JIT_PROVISIONING_ENABLED=false
AUTH_GITHUB_ALLOW_SIGNUP=true

# Assignment and notification workers
ALERT_EVALUATION_ENABLED=true
ASSIGNMENT_REFRESH_WORKER_ENABLED=true
ASSIGNMENT_REFRESH_WORKER_INTERVAL=5s
ASSIGNMENT_REFRESH_WORKER_BATCH_SIZE=25
ASSIGNMENT_REFRESH_WORKER_STALE_TIMEOUT=1m
NOTIFICATION_WORKER_ENABLED=true
NOTIFICATION_WORKER_INTERVAL=5s
NOTIFICATION_WORKER_BATCH_SIZE=25
NOTIFICATION_WORKER_STALE_TIMEOUT=1m
NOTIFICATION_HTTP_TIMEOUT=10s

# Email fallback. Admin settings can override these values.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS_MODE=starttls
SMTP_TIMEOUT=10s

# Optional OTLP HTTP trace ingest endpoint
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
