# Netstamp self-host defaults.
#
# Quickstart can run as-is on localhost. Before exposing Netstamp publicly,
# change every "change-me" value and set APP_ENV=production behind HTTPS.

NETSTAMP_IMAGE=yorukot/netstamp
NETSTAMP_VERSION=latest
NETSTAMP_PORT=3000

APP_ENV=local
DEMO_MODE=false
BACKEND_BASE_URL=
HTTP_TRUSTED_PROXIES=

DATABASE_PASSWORD=netstamp
AUTH_JWT_SECRET=change-me
LOG_PSEUDONYM_KEY=change-me

LOG_LEVEL=info
API_VERSION=v1

AUTH_REGISTRATION_ENABLED=true

VITE_NETSTAMP_REGISTRATION_ENABLED=true
VITE_NETSTAMP_PROJECT_CREATION_ENABLED=true
VITE_NETSTAMP_USER_CREDENTIAL_CHANGES_ENABLED=true
VITE_NETSTAMP_DEMO_MODE=false
VITE_NETSTAMP_DEMO_EMAIL=demo@netstamp.local
VITE_NETSTAMP_DEMO_PASSWORD=password
DEMO_BACKEND_BASE_URL=
