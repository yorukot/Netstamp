{
	"name": "@netstamp/api",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "tsp compile . --warn-as-error --no-emit",
		"check": "tsp compile . --warn-as-error --no-emit",
		"format": "tsp format \"**/*.tsp\" && prettier . --write",
		"format:check": "tsp format \"**/*.tsp\" --check && prettier --check .",
		"generate:openapi": "tsp compile . --warn-as-error",
		"lint": "tsp compile . --warn-as-error --no-emit"
	},
	"devDependencies": {
		"@typespec/compiler": "latest",
		"@typespec/http": "latest",
		"@typespec/openapi": "latest",
		"@typespec/openapi3": "latest",
		"prettier": "^3.8.3"
	},
	"packageManager": "pnpm@11.0.8+sha512.4c4097e1dd2d42372c4e7fa5a791ff28fc75a484c7ac192e64b1df0fdef17594ba982f9b4fed9adfb3c757846f565b799b2763fb3733d1de1bcb82cf46684912",
	"tspMain": "main.tsp"
}
