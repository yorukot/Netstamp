---
import { docsSearchIndex } from "../../data/docs";
import { Button, Input, Panel } from "@netstamp/ui";
import Icon from "../icons/Icon.astro";

const dataJson = JSON.stringify(docsSearchIndex);
---

<div class="docsSearch" data-docs-search data-search-index={dataJson}>
	<Button
		className="docsSearchTrigger"
		variant="outline"
		size="sm"
		type="button"
		data-search-open
		aria-label="Search documentation"
		aria-haspopup="dialog"
		aria-expanded="false"
		aria-controls="docs-search-dialog"
	>
		<span class="docsSearchTriggerLabel">
			<Icon name="search" size={16} />
			<span>Search</span>
		</span>
		<span class="docsSearchShortcut">Cmd K</span>
	</Button>

	<div class="docsSearchOverlay" id="docs-search-dialog" data-search-dialog hidden>
		<Button className="docsSearchScrim" variant="plain" type="button" aria-label="Close search" data-search-close />
		<Panel as="div" tone="glass" padded={false} className="docsSearchPanel" role="dialog" aria-modal="true" aria-labelledby="docs-search-title">
			<header class="docsSearchHeader">
				<div class="docsSearchTitle" id="docs-search-title">
					<Icon name="search" size={16} />
					<span>Search docs</span>
				</div>
				<Button className="docsSearchClose" variant="ghost" size="sm" type="button" data-search-close>Close</Button>
			</header>
			<label class="docsSearchInputLabel" for="docs-search-input">Search query</label>
			<Input
				id="docs-search-input"
				type="search"
				autoComplete="off"
				placeholder="Search documentation"
				aria-controls="docs-search-results"
				data-search-input
				frameClassName="docsSearchInputFrame"
				className="docsSearchInput"
			/>
			<div class="docsSearchResults" id="docs-search-results" role="listbox" aria-label="Search results" data-search-results hidden></div>
		</Panel>
	</div>
</div>

<script>
	import Fuse from "fuse.js";

	let cleanupSearch = () => {};

	function initDocsSearch() {
		cleanupSearch();

		const root = document.querySelector("[data-docs-search]");
		if (!(root instanceof HTMLElement)) return;

		const trigger = root.querySelector("[data-search-open]");
		const dialog = root.querySelector("[data-search-dialog]");
		const input = root.querySelector("[data-search-input]");
		const results = root.querySelector("[data-search-results]");
		const closeButtons = root.querySelectorAll("[data-search-close]");
		const entries = JSON.parse(root.dataset.searchIndex ?? "[]");
		const fuse = new Fuse(entries, {
			keys: ["title", "description", "keywords", "content"],
			threshold: 0.35,
			minMatchCharLength: 2
		});

		let restoreFocusTo: Element | null = null;
		let closeTimer: number | undefined;
		let activeResultIndex = -1;

		function clearResults() {
			if (!results) return;

			activeResultIndex = -1;
			results.replaceChildren();
			(results as HTMLElement).hidden = true;
		}

		function resultLinks() {
			return Array.from(results?.querySelectorAll("[data-search-result]") ?? []).filter((element): element is HTMLAnchorElement => element instanceof HTMLAnchorElement);
		}

		function focusResult(index: number) {
			const links = resultLinks();

			if (!links.length) return;

			activeResultIndex = (index + links.length) % links.length;
			links[activeResultIndex]?.focus();
		}

		function openSearch() {
			if (!dialog || !input) return;
			const dialogEl = dialog as HTMLElement;
			const triggerEl = trigger as HTMLButtonElement | null;

			if (!dialogEl.hidden && dialogEl.dataset.state === "open") return;

			if (closeTimer) {
				window.clearTimeout(closeTimer);
				closeTimer = undefined;
			}

			restoreFocusTo = document.activeElement;
			dialogEl.hidden = false;
			dialogEl.dataset.state = "open";
			triggerEl?.setAttribute("aria-expanded", "true");
			document.documentElement.classList.add("docsSearchOpen");
			(input as HTMLInputElement).value = "";
			clearResults();
			requestAnimationFrame(() => (input as HTMLElement).focus());
		}

		function closeSearch() {
			if (!dialog || !input) return;
			const dialogEl = dialog as HTMLElement;
			const triggerEl = trigger as HTMLButtonElement | null;

			if (dialogEl.hidden || dialogEl.dataset.state === "closing") return;

			dialogEl.dataset.state = "closing";
			triggerEl?.setAttribute("aria-expanded", "false");
			(input as HTMLInputElement).value = "";
			clearResults();

			closeTimer = window.setTimeout(() => {
				dialogEl.hidden = true;
				dialogEl.dataset.state = "closed";
				document.documentElement.classList.remove("docsSearchOpen");
				closeTimer = undefined;

				if (restoreFocusTo instanceof HTMLElement) {
					restoreFocusTo.focus();
				}
			}, 260);
		}

		function renderResults(matches: typeof entries) {
			if (!results) return;

			results.replaceChildren();

			if (!matches.length) {
				const empty = document.createElement("div");
				empty.className = "docsSearchEmpty";
				empty.setAttribute("role", "status");
				empty.textContent = "No matches";
				results.append(empty);
				(results as HTMLElement).hidden = false;
				return;
			}

			const fragment = document.createDocumentFragment();
			for (const entry of matches) {
				const link = document.createElement("a");
				const title = document.createElement("strong");
				const description = document.createElement("span");

				link.className = "docsSearchResult";
				link.href = entry.href;
				link.setAttribute("role", "option");
				link.setAttribute("data-search-result", "");
				title.textContent = entry.title;
				description.textContent = entry.description;
				link.append(title, description);
				fragment.append(link);
			}

			results.append(fragment);
			(results as HTMLElement).hidden = false;
		}

		function handleInput(event: Event) {
			const query = (event.currentTarget as HTMLInputElement).value.trim();
			if (!query) {
				clearResults();
				return;
			}

			const matches = fuse
				.search(query)
				.map(r => r.item)
				.slice(0, 6);
			renderResults(matches);
		}

		function handleSearchKeydown(event: KeyboardEvent) {
			if (event.key === "ArrowDown") {
				event.preventDefault();
				focusResult(0);
				return;
			}

			if (event.key === "Escape") {
				event.preventDefault();
				closeSearch();
			}
		}

		function handleResultsKeydown(event: KeyboardEvent) {
			if (event.key === "ArrowDown") {
				event.preventDefault();
				focusResult(activeResultIndex + 1);
				return;
			}

			if (event.key === "ArrowUp") {
				event.preventDefault();
				if (activeResultIndex <= 0) {
					(input as HTMLElement | null)?.focus();
					activeResultIndex = -1;
					return;
				}
				focusResult(activeResultIndex - 1);
				return;
			}

			if (event.key === "Escape") {
				event.preventDefault();
				closeSearch();
			}
		}

		function handleKeydown(event: KeyboardEvent) {
			if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "k") {
				event.preventDefault();
				openSearch();
				return;
			}

			if (event.key === "Escape" && dialog && !(dialog as HTMLElement).hidden) {
				closeSearch();
			}
		}

		trigger?.addEventListener("click", openSearch);
		closeButtons.forEach(button => button.addEventListener("click", closeSearch));
		input?.addEventListener("input", handleInput);
		input?.addEventListener("keydown", handleSearchKeydown);
		results?.addEventListener("keydown", handleResultsKeydown);
		document.addEventListener("keydown", handleKeydown);

		cleanupSearch = () => {
			if (closeTimer) window.clearTimeout(closeTimer);
			trigger?.removeEventListener("click", openSearch);
			closeButtons.forEach(button => button.removeEventListener("click", closeSearch));
			input?.removeEventListener("input", handleInput);
			input?.removeEventListener("keydown", handleSearchKeydown);
			results?.removeEventListener("keydown", handleResultsKeydown);
			document.removeEventListener("keydown", handleKeydown);
			document.documentElement.classList.remove("docsSearchOpen");
			cleanupSearch = () => {};
		};
	}

	initDocsSearch();
	document.addEventListener("astro:page-load", initDocsSearch);
</script>

<style>
	.docsSearch {
		display: grid;
	}

	:global(.docsSearchOpen) {
		overflow: hidden;
	}

	:global(.docsSearchOpen .docsSidebar) {
		z-index: 90;
	}

	:global(.docsSearchTrigger) {
		width: 100%;
		justify-content: space-between;
		flex-wrap: nowrap;
		overflow: hidden;
		gap: 0.75rem;
		padding: 0.4rem 0.625rem;
		font-family: var(--ns-font-mono);
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	:global(.docsSearchTrigger:hover) {
		--ns-frame-color: var(--ns-accent-border);
		background: color-mix(in srgb, var(--ns-accent) 8%, transparent);
	}

	:global(.docsSearchTriggerLabel) {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		min-width: 0;
		flex: 1;
		overflow: hidden;
	}

	:global(.docsSearchShortcut) {
		padding: 0.25rem 0.4rem;
		color: var(--ns-text-low);
		border: 1px solid var(--ns-border-faint);
		font-size: 0.62rem;
		letter-spacing: 0.08em;
		flex-shrink: 0;
		white-space: nowrap;
	}

	.docsSearchInputLabel {
		position: absolute;
		width: 1px;
		height: 1px;
		overflow: hidden;
		clip: rect(0 0 0 0);
		clip-path: inset(50%);
		white-space: nowrap;
	}

	.docsSearchOverlay[hidden],
	:global(.docsSearchResults[hidden]) {
		display: none !important;
	}

	.docsSearchOverlay {
		position: fixed;
		inset: 0;
		z-index: 80;
		display: grid;
		place-items: start center;
		padding: clamp(5rem, 12vh, 8rem) 1rem 1rem;
		opacity: 0;
	}

	.docsSearchOverlay[data-state="open"] {
		opacity: 1;
		animation: docsSearchOverlayIn 240ms ease both;
	}

	.docsSearchOverlay[data-state="closing"] {
		animation: docsSearchOverlayOut 240ms ease forwards;
	}

	:global(.docsSearchScrim) {
		position: absolute;
		inset: 0;
		padding: 0;
		border: 0;
		background: var(--ns-overlay-scrim);
		backdrop-filter: blur(0.5rem);
		cursor: default;
		appearance: none;
	}

	:global(.docsSearchPanel) {
		position: relative;
		z-index: 1;
		display: grid;
		gap: 1rem;
		width: min(42rem, calc(100vw - 2rem));
		padding: 1rem;
	}

	.docsSearchOverlay[data-state="open"] :global(.docsSearchPanel) {
		animation: docsSearchPanelIn 280ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
	}

	.docsSearchOverlay[data-state="closing"] :global(.docsSearchPanel) {
		animation: docsSearchPanelOut 240ms ease forwards;
	}

	.docsSearchHeader {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.docsSearchTitle {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		color: var(--ns-text);
		font-family: var(--ns-font-mono);
		font-size: 0.78rem;
		font-weight: 900;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	:global(.docsSearchClose) {
		font-family: var(--ns-font-mono);
		font-size: 0.65rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	:global(.docsSearchInputFrame) {
		--ns-frame-color: var(--ns-border-faint);
	}

	:global(.docsSearchInput) {
		min-height: 4.5rem;
		background: var(--ns-surface-raised);
		font-family: var(--ns-font-mono);
		font-size: clamp(1rem, 2vw, 1.25rem);
	}

	:global(.docsSearchResults) {
		display: grid;
		gap: 0.35rem;
		max-height: min(24rem, 48vh);
		overflow: auto;
	}

	:global(.docsSearchResult),
	:global(.docsSearchEmpty) {
		display: grid;
		gap: 0.2rem;
		padding: 0.75rem;
		color: var(--ns-text-muted);
		border: 1px solid transparent;
		text-decoration: none;
	}

	:global(.docsSearchResult:hover),
	:global(.docsSearchResult:focus-visible) {
		border-color: var(--ns-accent-border);
		background: color-mix(in srgb, var(--ns-accent) 10%, transparent);
	}

	:global(.docsSearchResult strong) {
		color: var(--ns-text);
		font-family: var(--ns-font-mono);
		font-size: 0.78rem;
		text-transform: uppercase;
	}

	:global(.docsSearchResult span),
	:global(.docsSearchEmpty) {
		font-size: 0.8rem;
		line-height: 1.4;
	}

	:global(.docsSearchTrigger:focus-visible),
	:global(.docsSearchClose:focus-visible),
	:global(.docsSearchInputFrame:focus-within),
	:global(.docsSearchResult:focus-visible) {
		outline: var(--ns-focus-outline);
		outline-offset: 0.25rem;
	}

	:global(.docsShell.sidebarFolded .docsSearchTrigger) {
		width: 100%;
		min-width: 0;
		align-items: center;
		justify-content: center;
		padding-inline: 0;
	}

	:global(.docsShell.sidebarFolded .docsSearchTriggerLabel) {
		flex: 0 0 auto;
		justify-content: center;
	}

	:global(.docsShell.sidebarFolded .docsSearchTriggerLabel span),
	:global(.docsShell.sidebarFolded .docsSearchShortcut) {
		display: none;
	}

	@media (max-width: 68rem) {
		:global(.docsShell.sidebarFolded .docsSearchTrigger) {
			justify-content: flex-start;
		}

		:global(.docsShell.sidebarFolded .docsSearchTriggerLabel span) {
			display: inline;
		}

		:global(.docsShell.sidebarFolded .docsSearchShortcut) {
			display: inline-block;
		}
	}

	@keyframes docsSearchOverlayIn {
		from {
			opacity: 0;
		}

		to {
			opacity: 1;
		}
	}

	@keyframes docsSearchOverlayOut {
		from {
			opacity: 1;
		}

		to {
			opacity: 0;
		}
	}

	@keyframes docsSearchPanelIn {
		from {
			opacity: 0;
			transform: translateY(-0.75rem) scale(0.96);
		}

		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	@keyframes docsSearchPanelOut {
		from {
			opacity: 1;
			transform: translateY(0) scale(1);
		}

		to {
			opacity: 0;
			transform: translateY(-0.5rem) scale(0.97);
		}
	}
</style>
