---
import { docsSearchIndex } from "../../data/docs";
import { Button, Input, Panel } from "@netstamp/ui";
import Icon from "../icons/Icon.astro";

const dataJson = JSON.stringify(docsSearchIndex);
---

<div class="docsSearch" data-docs-search data-search-index={dataJson}>
	<Button
		className="docsSearchTrigger"
		variant="outline"
		size="sm"
		type="button"
		data-search-open
		aria-label="Search documentation"
		aria-haspopup="dialog"
		aria-expanded="false"
		aria-controls="docs-search-dialog"
	>
		<span class="docsSearchTriggerLabel">
			<Icon name="search" size={16} />
			<span>Search</span>
		</span>
		<span class="docsSearchShortcut">Cmd K</span>
	</Button>

	<div class="docsSearchOverlay" id="docs-search-dialog" data-search-dialog hidden>
		<Button className="docsSearchScrim" variant="plain" type="button" aria-label="Close search" tabIndex={-1} data-search-close />
		<Panel as="div" tone="glass" padded={false} className="docsSearchPanel" role="dialog" aria-modal="true" aria-labelledby="docs-search-title">
			<header class="docsSearchHeader">
				<h2 class="docsSearchTitle" id="docs-search-title">
					<Icon name="search" size={16} />
					<span>Search docs</span>
				</h2>
				<Button className="docsSearchClose" variant="ghost" size="sm" type="button" data-search-close>Close</Button>
			</header>
			<label class="docsSearchInputLabel" for="docs-search-input">Search query</label>
			<Input
				id="docs-search-input"
				type="search"
				autoComplete="off"
				placeholder="Search documentation…"
				aria-controls="docs-search-results"
				data-search-input
				frameClassName="docsSearchInputFrame"
				className="docsSearchInput"
			/>
			<div class="docsSearchResults" id="docs-search-results" aria-label="Search results" data-search-results hidden></div>
		</Panel>
	</div>
</div>

<script>
	import "../../scripts/docsSearch";
</script>

<style>
	.docsSearch {
		display: grid;
	}

	:global(.docsSearchOpen) {
		overflow: hidden;
	}

	:global(.docsSearchOpen .docsSidebar) {
		z-index: 90;
	}

	:global(.docsSearchTrigger) {
		--ns-frame-color: transparent;
		width: 100%;
		min-height: 2.5rem;
		justify-content: space-between;
		flex-wrap: nowrap;
		overflow: hidden;
		gap: 0.75rem;
		padding: 0.5rem 0.75rem;
		color: var(--ns-text-subtle);
		background: color-mix(in srgb, var(--ns-surface) 72%, var(--ns-bg-subtle));
		font-family: var(--ns-font-sans);
		font-size: 0.875rem;
		font-weight: 500;
		letter-spacing: 0;
		text-transform: none;
	}

	:global(.docsSearchTrigger:hover) {
		--ns-frame-color: transparent;
		color: var(--ns-text);
		background: color-mix(in srgb, var(--ns-primary) 8%, var(--ns-surface));
	}

	:global(.docsSearchTriggerLabel) {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		min-width: 0;
		flex: 1;
		overflow: hidden;
	}

	:global(.docsSearchShortcut) {
		padding: 0;
		color: var(--ns-text-low);
		border: 0;
		background: transparent;
		font-family: var(--ns-font-mono);
		font-size: 0.68rem;
		font-weight: 750;
		letter-spacing: 0.03em;
		flex-shrink: 0;
		white-space: nowrap;
	}

	.docsSearchInputLabel {
		position: absolute;
		width: 1px;
		height: 1px;
		overflow: hidden;
		clip: rect(0 0 0 0);
		clip-path: inset(50%);
		white-space: nowrap;
	}

	.docsSearchOverlay[hidden],
	:global(.docsSearchResults[hidden]) {
		display: none !important;
	}

	.docsSearchOverlay {
		position: fixed;
		inset: 0;
		z-index: 80;
		display: grid;
		place-items: start center;
		padding: clamp(5rem, 12vh, 8rem) 1rem 1rem;
		opacity: 0;
	}

	.docsSearchOverlay[data-state="open"] {
		opacity: 1;
		animation: docsSearchOverlayIn 240ms ease both;
	}

	.docsSearchOverlay[data-state="closing"] {
		animation: docsSearchOverlayOut 240ms ease forwards;
	}

	:global(.docsSearchScrim) {
		position: absolute;
		inset: 0;
		padding: 0;
		border: 0;
		background: color-mix(in srgb, var(--ns-bg) 58%, transparent);
		backdrop-filter: blur(1.125rem) saturate(0.9);
		cursor: default;
		appearance: none;
		-webkit-backdrop-filter: blur(1.125rem) saturate(0.9);
	}

	:global(.docsSearchPanel) {
		--ns-frame-color: color-mix(in srgb, var(--ns-border) 72%, transparent);
		position: relative;
		z-index: 1;
		display: grid;
		gap: 1rem;
		width: min(42rem, calc(100vw - 2rem));
		max-height: calc(100svh - 2rem);
		min-width: 0;
		box-sizing: border-box;
		overflow: hidden;
		padding: 1rem;
		background: color-mix(in srgb, var(--ns-surface) 92%, var(--ns-bg-subtle));
	}

	.docsSearchOverlay[data-state="open"] :global(.docsSearchPanel) {
		animation: docsSearchPanelIn 280ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
	}

	.docsSearchOverlay[data-state="closing"] :global(.docsSearchPanel) {
		animation: docsSearchPanelOut 240ms ease forwards;
	}

	.docsSearchHeader {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.docsSearchTitle {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		margin: 0;
		color: var(--ns-text);
		font-family: var(--ns-font-mono);
		font-size: 0.78rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	:global(.docsSearchClose) {
		font-family: var(--ns-font-mono);
		font-size: 0.65rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	:global(.docsSearchInputFrame) {
		--ns-frame-color: transparent;
		width: 100%;
		min-width: 0;
		box-sizing: border-box;
		background: var(--ns-bg-subtle);
	}

	:global(.docsSearchInputFrame:has(.docsSearchInput:focus-visible)) {
		outline-offset: -2px;
	}

	:global(.docsSearchInput) {
		min-height: 3.25rem;
		width: 100%;
		min-width: 0;
		box-sizing: border-box;
		background: transparent;
		font-family: var(--ns-font-sans);
		font-size: 1rem;
		font-weight: 500;
	}

	:global(.docsSearchResults) {
		display: grid;
		gap: 0.25rem;
		width: 100%;
		min-width: 0;
		max-height: min(24rem, calc(100svh - 14rem));
		overflow: auto;
		overflow-x: hidden;
		scrollbar-gutter: stable;
	}

	:global(.docsSearchResult),
	:global(.docsSearchEmpty) {
		display: grid;
		gap: 0.25rem;
		min-width: 0;
		box-sizing: border-box;
		padding: 0.75rem 1rem;
		color: var(--ns-text-muted);
		border-left: 2px solid transparent;
		text-decoration: none;
	}

	:global(.docsSearchResult:hover),
	:global(.docsSearchResult:focus-visible) {
		border-left-color: var(--ns-primary);
		background: var(--ns-primary-muted);
	}

	:global(.docsSearchResult strong) {
		color: var(--ns-text);
		font-family: var(--ns-font-mono);
		font-size: 0.78rem;
		text-transform: uppercase;
	}

	:global(.docsSearchResult span),
	:global(.docsSearchEmpty) {
		font-size: 0.8rem;
		line-height: 1.4;
	}

	:global(.docsSearchTrigger:focus-visible),
	:global(.docsSearchClose:focus-visible),
	:global(.docsSearchResult:focus-visible) {
		outline: var(--ns-focus-outline);
		outline-offset: 0.25rem;
	}

	@keyframes docsSearchOverlayIn {
		from {
			opacity: 0;
		}

		to {
			opacity: 1;
		}
	}

	@keyframes docsSearchOverlayOut {
		from {
			opacity: 1;
		}

		to {
			opacity: 0;
		}
	}

	@keyframes docsSearchPanelIn {
		from {
			opacity: 0;
			transform: translateY(-0.75rem) scale(0.96);
		}

		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	@keyframes docsSearchPanelOut {
		from {
			opacity: 1;
			transform: translateY(0) scale(1);
		}

		to {
			opacity: 0;
			transform: translateY(-0.5rem) scale(0.97);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.docsSearchOverlay[data-state],
		.docsSearchOverlay[data-state] :global(.docsSearchPanel) {
			animation-duration: 0.01ms;
		}
	}
</style>
