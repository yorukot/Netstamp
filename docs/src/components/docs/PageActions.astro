---
import chatGptLogoUrl from "@/assets/logos/ChatGPT.svg?url";
import claudeLogoUrl from "@/assets/logos/Claude.svg?url";
import Icon from "@/components/icons/Icon.astro";
import { uiForLocale } from "@/i18n/ui";
import { Button } from "@netstamp/ui";

interface Props {
	chatGptUrl: string;
	claudeUrl: string;
	markdownUrl: string;
}

const { chatGptUrl, claudeUrl, markdownUrl } = Astro.props;
const ui = uiForLocale(Astro.currentLocale);
---

<div class="docsPageActions" data-docs-page-actions data-copied-label={ui.pageActions.copied} data-no-content-label={ui.pageActions.noContent} data-markdown-url={markdownUrl}>
	<Button className="docsPageActionsToggle" variant="ghost" size="sm" type="button" data-docs-page-actions-toggle aria-expanded="false" aria-controls="docs-page-actions-menu">
		<Icon name="copy" size={16} />
		<span data-docs-action-label aria-live="polite">{ui.pageActions.copy}</span>
		<Icon name="caret" size={12} />
	</Button>
	<div class="docsPageActionsMenu" id="docs-page-actions-menu" data-docs-page-actions-menu hidden>
		<button class="docsPageActionItem" type="button" data-docs-copy-page>
			<span class="docsPageActionIcon" aria-hidden="true">
				<Icon name="copy" size={18} />
			</span>
			<span class="docsPageActionCopy">
				<strong data-docs-action-label>{ui.pageActions.copy}</strong>
				<small>{ui.pageActions.copyDescription}</small>
			</span>
		</button>
		<a class="docsPageActionItem" href={markdownUrl} target="_blank" rel="noreferrer" data-docs-view-markdown>
			<span class="docsPageActionIcon" aria-hidden="true">
				<Icon name="fileText" size={18} />
			</span>
			<span class="docsPageActionCopy">
				<strong>{ui.pageActions.viewMarkdown}</strong>
				<small>{ui.pageActions.viewMarkdownDescription}</small>
			</span>
		</a>
		<a class="docsPageActionItem" href={chatGptUrl} target="_blank" rel="noreferrer">
			<span class="docsPageActionIcon" aria-hidden="true">
				<img class="docsPageActionLogo docsPageActionLogoChatGpt" src={chatGptLogoUrl} alt="" width="18" height="18" loading="lazy" />
			</span>
			<span class="docsPageActionCopy">
				<strong>{ui.pageActions.openChatGpt}</strong>
				<small>{ui.pageActions.askDescription}</small>
			</span>
		</a>
		<a class="docsPageActionItem" href={claudeUrl} target="_blank" rel="noreferrer">
			<span class="docsPageActionIcon" aria-hidden="true">
				<img class="docsPageActionLogo" src={claudeLogoUrl} alt="" width="18" height="18" loading="lazy" />
			</span>
			<span class="docsPageActionCopy">
				<strong>{ui.pageActions.openClaude}</strong>
				<small>{ui.pageActions.askDescription}</small>
			</span>
		</a>
	</div>
</div>

<style>
	.docsPageActions {
		position: relative;
		display: grid;
		justify-items: start;
		max-width: 100%;
	}

	:global(.docsPageActionsToggle) {
		--ns-frame-color: transparent;
		display: inline-flex;
		align-items: center;
		justify-content: flex-start;
		gap: 0.5rem;
		width: fit-content;
		max-width: 100%;
		min-height: 2rem;
		padding: 0.25rem 0.5rem;
		color: var(--ns-text-subtle);
		background: transparent;
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0;
		line-height: 1.25;
		text-transform: none;
	}

	:global(.docsPageActionsToggle [data-docs-action-label]) {
		min-width: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	:global(.docsPageActionsToggle:hover),
	:global(.docsPageActionsToggle[aria-expanded="true"]) {
		--ns-frame-color: transparent;
		color: var(--ns-primary-hover);
		background: var(--ns-primary-muted);
	}

	:global(.docsPageActionsToggle:focus-visible) {
		outline: var(--ns-focus-outline);
		outline-offset: var(--ns-focus-outline-offset);
	}

	:global(.docsPageActionsToggle[aria-expanded="true"] > .icon:last-child) {
		transform: rotate(180deg);
	}

	.docsPageActionsMenu[hidden] {
		display: none;
	}

	.docsPageActionsMenu {
		position: absolute;
		top: calc(100% + 0.5rem);
		right: 0;
		z-index: var(--ns-z-popover);
		display: grid;
		width: min(18rem, calc(100vw - 2rem));
		max-height: calc(100svh - var(--docs-sticky-top) - 3.25rem);
		padding: 0.25rem;
		overflow-x: clip;
		overflow-y: auto;
		border: 1px solid var(--ns-border);
		background: var(--ns-surface-raised);
		box-shadow: none;
		animation: docs-page-actions-in 240ms cubic-bezier(0.2, 0.8, 0.2, 1);
		transform-origin: top right;
	}

	.docsPageActionItem {
		display: grid;
		grid-template-columns: 1.25rem minmax(0, 1fr);
		align-items: center;
		gap: 0.75rem;
		width: 100%;
		min-height: 3.5rem;
		padding: 0.5rem 0.75rem;
		color: var(--ns-text-muted);
		border: 0;
		border-top: 1px solid var(--ns-border-faint);
		background: transparent;
		font: inherit;
		line-height: 1.25;
		text-align: left;
		text-decoration: none;
		cursor: pointer;
		transition:
			background var(--ns-transition),
			color var(--ns-transition);
	}

	.docsPageActionItem:first-child {
		border-top: 0;
	}

	.docsPageActionItem:hover,
	.docsPageActionItem:focus-visible {
		color: var(--ns-text);
		background: var(--ns-primary-muted);
	}

	.docsPageActionItem:focus-visible {
		outline: var(--ns-focus-outline);
		outline-offset: calc(-1 * var(--ns-focus-outline-offset));
	}

	.docsPageActionIcon {
		display: inline-grid;
		place-items: center;
		width: 1.25rem;
		height: 1.25rem;
		color: var(--ns-text-low);
	}

	.docsPageActionIcon img {
		display: block;
		width: 1.125rem;
		height: 1.125rem;
		object-fit: contain;
	}

	:global(:root[data-theme="dark"]) .docsPageActionLogoChatGpt,
	:global(:root:not([data-theme])) .docsPageActionLogoChatGpt {
		filter: invert(1);
	}

	.docsPageActionCopy {
		display: grid;
		gap: 0.25rem;
		min-width: 0;
		overflow-wrap: anywhere;
	}

	.docsPageActionCopy strong {
		color: inherit;
		font-size: 0.84rem;
		font-weight: 680;
		letter-spacing: 0;
		line-height: 1.35;
	}

	.docsPageActionCopy small {
		color: var(--ns-text-low);
		font-size: 0.72rem;
		font-weight: 450;
		letter-spacing: 0;
		line-height: 1.5;
	}

	@keyframes docs-page-actions-in {
		from {
			opacity: 0;
			transform: translateY(-0.25rem);
		}

		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 68rem) {
		.docsPageActions {
			justify-items: stretch;
		}

		:global(.docsPageActionsToggle) {
			width: 100%;
			justify-content: space-between;
		}

		.docsPageActionsMenu {
			position: static;
			width: 100%;
			max-height: none;
			margin-top: 0.5rem;
			transform-origin: top center;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.docsPageActionsMenu {
			animation-duration: 1ms;
		}
	}
</style>
