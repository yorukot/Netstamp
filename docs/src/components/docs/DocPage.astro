---
import { render } from "astro:content";
import { getDocEntry } from "../../data/docs";
import DocLayout from "../../layouts/DocLayout.astro";
import LocalizedCodeBlock from "./LocalizedCodeBlock.astro";

interface Props {
	contentId: string;
}

const { contentId } = Astro.props;
const { entry, translated } = getDocEntry(contentId, Astro.currentLocale);

if (!entry) {
	throw new Error(`Missing English documentation source for ${contentId}.`);
}

const { Content, headings } = await render(entry);
const editPath = `docs/src/content/docs/${entry.id.endsWith(".mdx") ? entry.id : `${entry.id}.mdx`}`;
const fallback = Astro.currentLocale === "zh-TW" && !translated;
---

<DocLayout title={entry.data.title} description={entry.data.description} headings={headings} editPath={editPath} head={entry.data.head} fallback={fallback}>
	<Content components={{ CodeBlock: LocalizedCodeBlock }} />
</DocLayout>
