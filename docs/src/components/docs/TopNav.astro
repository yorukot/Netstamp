---
import netstampLogoLight from "@netstamp/brand/assets/netstamp-logo-light.svg?url";
import { Button } from "@netstamp/ui";
import { appUrl } from "../../lib/publicUrls";

const pathname = Astro.url.pathname;
const isHome = pathname === "/";
const isDocs = pathname.startsWith("/docs");
const isOpenAPI = pathname.startsWith("/openapi");
const demoHref = "https://demo.netstamp.dev";
const discordHref = "https://discord.gg/9mdkf6dyTy";
---

<nav class="siteNav" aria-label="Primary navigation">
	<div class="siteNavPrimary">
		<a class="siteBrand" href="/" aria-label="Netstamp home">
			<img class="siteBrandLogo siteBrandLogoLight" src={netstampLogoLight} alt="" aria-hidden="true" />
		</a>
	</div>
	<div class="siteNavLinks" aria-label="Docs sections">
		<a href="/docs/" class:list={["siteNavTextLink", isDocs && "active"]}>
			<span>Docs</span>
		</a>
		<a href="/openapi/" class:list={["siteNavTextLink", isOpenAPI && "active"]}>
			<span>API</span>
		</a>
		<a href="https://github.com/yorukot/netstamp" class="siteNavTextLink" target="_blank" rel="noreferrer">
			<span>GitHub</span>
		</a>
		<a href={discordHref} class="siteNavTextLink" target="_blank" rel="noreferrer">
			<span>Discord</span>
		</a>
	</div>
	<div class="siteNavActions">
		{
			!isHome ? (
				<Button className="siteThemeToggle" variant="outline" size="sm" type="button" data-theme-toggle aria-label="Switch color mode" title="Switch color mode">
					<ph-sun class="themeIcon themeIconSun" size="16" weight="bold" aria-hidden="true" />
					<ph-moon-stars class="themeIcon themeIconMoon" size="16" weight="bold" aria-hidden="true" />
				</Button>
			) : null
		}
		<a class="siteNavLogin" href={demoHref}>View Demo</a>
	</div>
</nav>

<style>
	.siteNav {
		position: fixed;
		top: 1rem;
		right: clamp(1rem, 4vw, 3rem);
		left: clamp(1rem, 4vw, 3rem);
		z-index: 40;
		display: grid;
		grid-template-columns: auto minmax(0, 1fr) auto;
		align-items: center;
		justify-content: stretch;
		gap: 1rem;
		min-height: 4rem;
		padding: 0.5rem 0.75rem 0.5rem 1rem;
		border: 1px solid color-mix(in srgb, var(--ns-chrome-text) 22%, transparent);
		color: var(--ns-chrome-text);
		background: var(--ns-chrome-bg);
	}

	.siteBrand {
		display: inline-flex;
		align-items: center;
		color: var(--ns-chrome-text);
		text-decoration: none;
	}

	.siteBrandLogo {
		display: block;
		width: 10.25rem;
		height: auto;
	}

	.siteNavPrimary,
	.siteNavActions {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.siteNavLinks {
		display: flex;
		align-items: center;
		justify-self: center;
		gap: 1.5rem;
		min-width: 0;
	}

	.siteNavActions {
		gap: 0.75rem;
		justify-self: end;
	}

	.siteNavTextLink {
		display: inline-flex;
		align-items: center;
		padding: 0;
		border: 0;
		color: var(--ns-chrome-text);
		background: transparent;
		font-family: var(--ns-font-sans);
		font-size: 0.875rem;
		font-weight: 400;
		letter-spacing: 0;
		text-decoration: none;
		text-transform: none;
		transition: color var(--ns-transition);
	}

	.siteNavTextLink,
	.siteNavTextLink:link,
	.siteNavTextLink:visited,
	.siteNavTextLink:hover,
	.siteNavTextLink:active,
	.siteNavTextLink:focus-visible,
	.siteNavTextLink span {
		border-bottom: 0 !important;
		box-shadow: none;
		text-decoration: none !important;
		text-decoration-line: none;
	}

	.siteNavTextLink:hover,
	.siteNavTextLink.active {
		color: var(--ns-primary-hover);
	}

	.siteBrand:focus-visible,
	.siteNavTextLink:focus-visible {
		outline: var(--ns-focus-outline);
		outline-offset: 0.25rem;
	}

	.siteNavLogin,
	:global(.siteThemeToggle) {
		justify-content: center;
	}

	:global(.siteThemeToggle) {
		--ns-frame-color: var(--ns-chrome-border);
		width: 2.25rem;
		min-width: 2.25rem;
		min-height: 2.25rem;
		padding: 0;
		color: var(--ns-chrome-text);
		background: transparent;
	}

	:global(.siteThemeToggle:hover) {
		--ns-frame-color: var(--ns-chrome-border);
		color: var(--ns-chrome-text);
		background: var(--ns-chrome-hover);
	}

	.siteNavLogin {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 5.75rem;
		min-height: 2.25rem;
		padding: 0.5rem 1rem;
		border: 1px solid var(--ns-chrome-text);
		color: var(--ns-chrome-bg);
		background: var(--ns-chrome-text);
		font-family: var(--ns-font-sans);
		font-size: 0.875rem;
		font-weight: 750;
		line-height: 1;
		text-decoration: none !important;
		text-decoration-line: none;
		text-transform: none;
		transition:
			background var(--ns-transition),
			border-color var(--ns-transition),
			color var(--ns-transition);
	}

	.siteNavLogin:link,
	.siteNavLogin:visited,
	.siteNavLogin:hover,
	.siteNavLogin:active,
	.siteNavLogin:focus-visible {
		text-decoration: none !important;
		text-decoration-line: none;
	}

	.siteNavLogin:hover,
	.siteNavLogin:active {
		border-color: color-mix(in srgb, var(--ns-chrome-text) 84%, var(--ns-primary));
		color: var(--ns-chrome-bg);
		background: color-mix(in srgb, var(--ns-chrome-text) 84%, var(--ns-primary));
	}

	.siteNavLogin:focus-visible {
		outline: var(--ns-focus-outline);
		outline-offset: 0.25rem;
	}

	.themeIconMoon,
	:global(:root[data-theme="light"]) .themeIconSun {
		display: none;
	}

	:global(:root[data-theme="light"]) .themeIconMoon {
		display: block;
	}

	@media (max-width: 48rem) {
		.siteNav {
			top: 0.75rem;
			right: 0.75rem;
			left: 0.75rem;
			grid-template-columns: auto auto;
			min-height: 3.5rem;
			padding: 0.5rem 0.75rem;
		}

		.siteNavLinks {
			grid-column: 1 / -1;
			order: 3;
			width: 100%;
			justify-content: space-between;
			gap: 0.75rem;
			padding-top: 0.375rem;
		}

		.siteNavPrimary {
			gap: 0.75rem;
		}

		.siteNavLogin {
			min-width: 4.5rem;
			min-height: 2rem;
			padding: 0.5rem 0.75rem;
			font-size: 0.75rem;
		}
	}

	@media (max-width: 34rem) {
		.siteBrandLogo {
			width: 8.75rem;
		}

		.siteNavTextLink {
			font-size: 0.75rem;
		}
	}
</style>
