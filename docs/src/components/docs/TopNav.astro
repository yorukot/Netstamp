---
import netstampLogoLight from "@netstamp/brand/assets/netstamp-logo-light.svg?url";
import { localeMetadata, stripLocalePrefix, supportedLocales } from "@netstamp/i18n";
import { Button } from "@netstamp/ui";
import { localeFromAstro, pathForLocale, uiForLocale } from "@/i18n/ui";

interface Props {
	pathname?: string;
}

const locale = localeFromAstro(Astro.currentLocale);
const ui = uiForLocale(locale);
const pathname = stripLocalePrefix(Astro.props.pathname ?? Astro.url.pathname);
const isHome = pathname === "/";
const isDocs = pathname.startsWith("/docs");
const isOpenAPI = pathname.startsWith("/openapi");
const languageOptions = supportedLocales.map(candidate => ({
	href: pathForLocale(pathname, candidate),
	isCurrent: candidate === locale,
	label: localeMetadata[candidate].label,
	locale: candidate
}));
const demoHref = "https://demo.netstamp.dev";
const discordHref = "https://discord.gg/9mdkf6dyTy";
---

<nav class="siteNav" aria-label={ui.nav.primary}>
	<div class="siteNavPrimary">
		<a class="siteBrand" href={pathForLocale("/", locale)} aria-label={ui.nav.home}>
			<img class="siteBrandLogo siteBrandLogoLight" src={netstampLogoLight} alt="" aria-hidden="true" />
		</a>
	</div>
	<div class="siteNavLinks" aria-label={ui.nav.sections}>
		<a href={pathForLocale("/docs/", locale)} class:list={["siteNavTextLink", isDocs && "active"]}>
			<span>{ui.nav.docs}</span>
		</a>
		<a href={pathForLocale("/openapi/", locale)} class:list={["siteNavTextLink", isOpenAPI && "active"]}>
			<span>{ui.nav.api}</span>
		</a>
		<a href="https://github.com/yorukot/netstamp" class="siteNavTextLink" target="_blank" rel="noreferrer">
			<span>GitHub</span>
		</a>
		<a href={discordHref} class="siteNavTextLink" target="_blank" rel="noreferrer">
			<span>Discord</span>
		</a>
	</div>
	<div class="siteNavActions">
		{
			!isHome ? (
				<Button
					className="siteThemeToggle"
					variant="outline"
					size="sm"
					type="button"
					data-theme-toggle
					data-theme-light-label={ui.nav.switchToLight}
					data-theme-dark-label={ui.nav.switchToDark}
					aria-label={ui.nav.switchColor}
					title={ui.nav.switchColor}
				>
					<ph-sun class="themeIcon themeIconSun" size="16" weight="bold" aria-hidden="true" focusable="false" />
					<ph-moon-stars class="themeIcon themeIconMoon" size="16" weight="bold" aria-hidden="true" focusable="false" />
				</Button>
			) : null
		}
		<div class="siteLanguageMenu" data-language-menu>
			<Button
				className="siteLanguageTrigger"
				variant="outline"
				size="sm"
				type="button"
				aria-label={ui.common.language}
				aria-haspopup="menu"
				aria-expanded="false"
				aria-controls="site-language-menu"
				title={ui.common.language}
				data-language-menu-trigger
			>
				<ph-translate size="16" weight="bold" aria-hidden="true" focusable="false"></ph-translate>
				<span class="siteLanguageLabel">{ui.common.language}</span>
			</Button>
			<div class="siteLanguageMenuContent" id="site-language-menu" role="menu" aria-label={ui.common.language} data-language-menu-content data-state="closed" hidden>
				{
					languageOptions.map(option => (
						<a
							class:list={["siteLanguageOption", option.isCurrent && "current"]}
							href={option.href}
							lang={localeMetadata[option.locale].htmlLang}
							hreflang={option.locale}
							role="menuitem"
							aria-current={option.isCurrent ? "page" : undefined}
							data-language-menu-item
						>
							<span>{option.label}</span>
							{option.isCurrent ? <ph-check size="16" weight="bold" aria-hidden="true" focusable="false" /> : null}
						</a>
					))
				}
			</div>
		</div>
		<a class="siteNavLogin" href={demoHref}>{ui.nav.viewDemo}</a>
	</div>
</nav>

<style>
	.siteNav {
		position: fixed;
		top: 1rem;
		right: clamp(1rem, 4vw, 3rem);
		left: clamp(1rem, 4vw, 3rem);
		z-index: var(--ns-z-navigation);
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
		align-items: center;
		justify-content: stretch;
		gap: 1rem;
		min-height: 4rem;
		padding: 0.5rem 0.75rem;
		border: 0;
		color: var(--ns-chrome-text);
		background: var(--ns-chrome-bg);
	}

	.siteBrand {
		display: inline-flex;
		align-items: center;
		color: var(--ns-chrome-text);
		text-decoration: none;
	}

	.siteBrandLogo {
		display: block;
		width: 10.25rem;
		height: auto;
	}

	.siteNavPrimary,
	.siteNavActions {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.siteNavPrimary {
		justify-self: start;
	}

	.siteNavLinks {
		display: flex;
		align-items: center;
		justify-self: center;
		gap: 1.5rem;
		min-width: 0;
	}

	.siteNavActions {
		gap: 0.75rem;
		justify-self: end;
	}

	.siteNavTextLink {
		display: inline-flex;
		align-items: center;
		padding: 0;
		border: 0;
		color: var(--ns-chrome-text);
		background: transparent;
		font-size: 0.875rem;
		font-weight: 400;
		letter-spacing: 0;
		text-decoration: none;
		text-transform: none;
		transition: color var(--ns-transition);
	}

	.siteNavTextLink,
	.siteNavTextLink:link,
	.siteNavTextLink:visited,
	.siteNavTextLink:hover,
	.siteNavTextLink:active,
	.siteNavTextLink:focus-visible,
	.siteNavTextLink span {
		border-bottom: 0 !important;
		box-shadow: none;
		text-decoration: none !important;
		text-decoration-line: none;
	}

	.siteNavTextLink:hover,
	.siteNavTextLink.active {
		color: var(--ns-primary-hover);
	}

	.siteBrand:focus-visible,
	.siteNavTextLink:focus-visible {
		outline: var(--ns-focus-outline);
		outline-offset: 0.25rem;
	}

	.siteNavLogin,
	:global(.siteLanguageTrigger),
	:global(.siteThemeToggle) {
		justify-content: center;
	}

	.siteLanguageMenu {
		position: relative;
	}

	:global(.siteLanguageTrigger) {
		--ns-frame-color: var(--ns-chrome-border);
		gap: 0.5rem;
		min-height: 2.25rem;
		padding: 0.5rem 0.75rem;
		color: var(--ns-chrome-text);
		background: transparent;
	}

	:global(.siteLanguageTrigger:hover),
	:global(.siteLanguageTrigger[aria-expanded="true"]) {
		--ns-frame-color: var(--ns-chrome-border);
		color: var(--ns-chrome-text);
		background: var(--ns-chrome-hover);
	}

	:global(.siteLanguageTrigger ph-translate) {
		color: var(--ns-primary);
	}

	.siteLanguageMenuContent {
		position: absolute;
		top: calc(100% + 0.5rem);
		right: 0;
		z-index: var(--ns-z-popover);
		min-width: 10rem;
		padding: 0.25rem;
		border: 1px solid var(--ns-chrome-border);
		color: var(--ns-chrome-text);
		background: var(--ns-chrome-bg);
		transform-origin: top right;
	}

	.siteLanguageMenuContent[hidden] {
		display: none;
	}

	.siteLanguageMenuContent[data-state="open"] {
		animation: siteLanguageMenuIn 220ms cubic-bezier(0.2, 0.8, 0.2, 1);
	}

	.siteLanguageMenuContent[data-state="closed"]:not([hidden]) {
		animation: siteLanguageMenuOut 160ms ease-in forwards;
		pointer-events: none;
	}

	.siteLanguageOption {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		min-height: 2.25rem;
		padding: 0.5rem 0.75rem;
		color: var(--ns-chrome-text-muted);
		font-size: 0.8125rem;
		font-weight: 650;
		line-height: 1.2;
		text-decoration: none;
	}

	.siteLanguageOption:hover,
	.siteLanguageOption.current {
		color: var(--ns-chrome-text);
		background: var(--ns-chrome-hover);
	}

	.siteLanguageOption:focus-visible {
		outline: var(--ns-focus-outline);
		outline-offset: var(--ns-focus-outline-offset);
	}

	.siteLanguageOption ph-check {
		flex: 0 0 auto;
		color: var(--ns-primary);
	}

	@keyframes siteLanguageMenuIn {
		from {
			opacity: 0;
			transform: translateY(-0.25rem) scale(0.98);
		}

		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	@keyframes siteLanguageMenuOut {
		from {
			opacity: 1;
			transform: translateY(0) scale(1);
		}

		to {
			opacity: 0;
			transform: translateY(-0.25rem) scale(0.98);
		}
	}

	:global(.siteThemeToggle) {
		--ns-frame-color: var(--ns-chrome-border);
		width: 2.25rem;
		min-width: 2.25rem;
		min-height: 2.25rem;
		padding: 0;
		color: var(--ns-chrome-text);
		background: transparent;
	}

	:global(.siteThemeToggle:hover) {
		--ns-frame-color: var(--ns-chrome-border);
		color: var(--ns-chrome-text);
		background: var(--ns-chrome-hover);
	}

	.siteNavLogin {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 5.75rem;
		min-height: 2.25rem;
		padding: 0.5rem 1rem;
		border: 1px solid var(--ns-chrome-text);
		color: var(--ns-chrome-bg);
		background: var(--ns-chrome-text);
		font-size: 0.875rem;
		font-weight: 750;
		line-height: 1;
		text-decoration: none !important;
		text-decoration-line: none;
		text-transform: none;
		transition:
			background var(--ns-transition),
			border-color var(--ns-transition),
			color var(--ns-transition);
	}

	.siteNavLogin:link,
	.siteNavLogin:visited,
	.siteNavLogin:hover,
	.siteNavLogin:active,
	.siteNavLogin:focus-visible {
		text-decoration: none !important;
		text-decoration-line: none;
	}

	.siteNavLogin:hover,
	.siteNavLogin:active {
		border-color: color-mix(in srgb, var(--ns-chrome-text) 84%, var(--ns-primary));
		color: var(--ns-chrome-bg);
		background: color-mix(in srgb, var(--ns-chrome-text) 84%, var(--ns-primary));
	}

	.siteNavLogin:focus-visible {
		outline: var(--ns-focus-outline);
		outline-offset: 0.25rem;
	}

	.themeIconMoon,
	:global(:root[data-theme="light"]) .themeIconSun {
		display: none;
	}

	:global(:root[data-theme="light"]) .themeIconMoon {
		display: block;
	}

	@media (max-width: 48rem) {
		.siteNav {
			top: 0.75rem;
			right: 0.75rem;
			left: 0.75rem;
			grid-template-columns: auto auto;
			min-height: 3.5rem;
			padding: 0.5rem 0.75rem;
		}

		.siteNavLinks {
			grid-column: 1 / -1;
			order: 3;
			width: 100%;
			justify-content: space-between;
			gap: 0.75rem;
			padding-top: 0.375rem;
		}

		.siteNavPrimary {
			gap: 0.75rem;
		}

		.siteNavLogin {
			min-width: 4.5rem;
			min-height: 2rem;
			padding: 0.5rem 0.75rem;
			font-size: 0.75rem;
		}
	}

	@media (max-width: 34rem) {
		.siteBrandLogo {
			width: 8.75rem;
		}

		.siteLanguageLabel {
			display: none;
		}

		:global(.siteLanguageTrigger) {
			width: 2.25rem;
			min-width: 2.25rem;
			padding: 0;
		}

		.siteNavTextLink {
			font-size: 0.75rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.siteLanguageMenuContent[data-state] {
			animation-duration: 1ms;
		}
	}
</style>
