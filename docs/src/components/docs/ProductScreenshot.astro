---
import type { ImageMetadata } from "astro";

interface Props {
	src: ImageMetadata;
	alt: string;
	caption: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="productScreenshot">
	<img src={src.src} alt={alt} width={src.width} height={src.height} loading="lazy" decoding="async" />
	<figcaption>{caption}</figcaption>
</figure>

<style>
	.productScreenshot {
		margin: 1.5rem 0;
	}

	.productScreenshot img {
		display: block;
		width: 100%;
		height: auto;
		background: var(--ns-surface-deep);
		border: 1px solid var(--ns-border);
	}

	.productScreenshot figcaption {
		margin-top: 0.5rem;
		color: var(--ns-text-subtle);
		font-size: 0.875rem;
		line-height: 1.5;
	}
</style>
