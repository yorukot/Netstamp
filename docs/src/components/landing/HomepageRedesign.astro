---
import FaqSection from "./homepage/FaqSection.astro";
import FinalCtaSection from "./homepage/FinalCtaSection.astro";
import HeroSection from "./homepage/HeroSection.astro";
import ProductIntroSection from "./homepage/ProductIntroSection.astro";
import ProductShowcaseSection from "./homepage/ProductShowcaseSection.astro";
import ScrollFlowSection from "./homepage/ScrollFlowSection.astro";
---

<div class="homepage" data-homepage>
	<main>
		<HeroSection />
		<ProductIntroSection />
		<ScrollFlowSection />
		<ProductShowcaseSection />
		<FinalCtaSection />
		<FaqSection />
	</main>

	<script>
		import "../../scripts/homepageRedesign";
	</script>

	<style is:global>
		html {
			scroll-behavior: smooth;
		}

		.homepage,
		.homepage *,
		.homepage *::before,
		.homepage *::after {
			box-sizing: border-box;
		}

		.homepage {
			--home-black: #000000;
			--home-ink: #050505;
			--home-chrome: #131518;
			--home-white: #ffffff;
			--home-paper: #f5f6f8;
			--home-paper-strong: #ffffff;
			--home-paper-soft: #eef1f5;
			--home-line: #cbd3df;
			--home-line-dark: #3d4650;
			--home-line-faint: rgba(148, 163, 184, 0.32);
			--home-muted: #526176;
			--home-muted-dark: #8d98a8;
			--home-orange: #ea6a1a;
			--home-orange-hot: #f97316;
			--home-orange-soft: #fff1e7;
			--home-green: #168a45;
			--home-red: #c9362c;
			overflow: clip;
			color: var(--home-ink);
			background: var(--home-white);
			font-family: var(--ns-font-sans);
		}

		body:has(.homepage) {
			background: var(--home-white);
		}

		body:has(.homepage) .trackingConsent,
		body:has(.homepage) .siteThemeToggle {
			display: none !important;
		}

		.homepage main {
			overflow: clip;
		}

		.homepage section[id] {
			scroll-margin-top: 6.5rem;
		}

		.homepage a {
			color: inherit;
		}

		.homepage .btn {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			min-height: 2.75rem;
			padding: 0 1.35rem;
			border: 1px solid transparent;
			border-radius: 0;
			font-family: var(--ns-font-sans);
			font-size: 0.9rem;
			font-weight: 700;
			letter-spacing: 0;
			line-height: 1;
			text-decoration: none;
			transition:
				background 160ms ease,
				border-color 160ms ease,
				color 160ms ease,
				transform 160ms ease;
		}

		.homepage .btn:hover {
			transform: translateY(-1px);
		}

		.homepage .btn:focus-visible,
		.homepage summary:focus-visible {
			outline: 2px solid var(--home-orange);
			outline-offset: 4px;
		}

		.homepage .btn-primary {
			border-color: var(--home-orange);
			color: #ffffff;
			background: var(--home-orange);
		}

		.homepage .btn-primary:hover {
			border-color: var(--home-orange-hot);
			background: var(--home-orange-hot);
		}

		.homepage .btn-outline {
			border-color: rgba(255, 255, 255, 0.42);
			color: #ffffff;
			background: rgba(255, 255, 255, 0.04);
		}

		.homepage .btn-outline:hover {
			border-color: rgba(255, 255, 255, 0.72);
			background: rgba(255, 255, 255, 0.12);
		}

		.homepage .cta-row {
			display: flex;
			flex-wrap: wrap;
			justify-content: center;
			gap: 0.75rem;
		}

		.homepage .sr-only {
			position: absolute;
			width: 1px;
			height: 1px;
			padding: 0;
			margin: -1px;
			overflow: hidden;
			clip: rect(0, 0, 0, 0);
			white-space: nowrap;
			border: 0;
		}

		@media (max-width: 38rem) {
			.homepage .btn {
				width: 100%;
				min-height: 3rem;
			}

			.homepage .cta-row {
				width: 100%;
			}
		}

		@media (prefers-reduced-motion: reduce) {
			html {
				scroll-behavior: auto;
			}

			.homepage *,
			.homepage *::before,
			.homepage *::after {
				animation-duration: 0.001ms !important;
				animation-iteration-count: 1 !important;
				scroll-behavior: auto !important;
				transition-duration: 0.001ms !important;
			}
		}
	</style>
</div>
