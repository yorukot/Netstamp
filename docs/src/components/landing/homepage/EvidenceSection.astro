<section id="green-dot" class="green-dot section-dark" aria-labelledby="green-dot-title">
	<div class="section-intro centered">
		<p class="section-kicker dark"><span class="marker"></span> Evidence layer</p>
		<h2 id="green-dot-title">A green dot is not enough.</h2>
		<p>Netstamp shows why a service looks healthy, where it was measured from, and which path the packet actually took.</p>
	</div>
	<div class="evidence-stage">
		<div class="service-target">
			<p>api.example.com</p>
			<strong>STATUS operational</strong>
			<span>latest result verified by 18 probes</span>
		</div>
		<div class="evidence-list" data-evidence-list>
			<button type="button" data-panel="Probe heartbeat|TPE last seen 8s ago|agent 0.8.4 online">Probe heartbeat<span>TPE last seen 8s ago</span></button>
			<button type="button" data-panel="HTTP uptime|200 OK, 118ms response|24h availability 99.98%">HTTP uptime<span>200 OK, 118ms response</span></button>
			<button type="button" data-panel="DNS resolution|A record resolved in 32ms|answer unchanged">DNS resolution<span>A record resolved in 32ms</span></button>
			<button type="button" data-panel="Ping latency|42ms average, 61ms p95|0.08% loss">Ping latency<span>42ms average, 61ms p95</span></button>
			<button type="button" data-panel="TCP reachability|443 successful, 38ms connect|failure percent 0.02%">TCP reachability<span>443 successful</span></button>
			<button type="button" data-panel="Traceroute path|12 hops, destination reached|provider changed at hop 6">Traceroute path<span>12 hops, reached</span></button>
		</div>
	</div>
</section>
