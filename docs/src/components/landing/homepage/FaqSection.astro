---
const faqs = [
	{
		question: "Is Netstamp just another uptime monitor?",
		answer:
			"No. Uptime is only one layer. Netstamp combines real-world probes, ping, TCP reachability, traceroute, HTTP uptime, TLS certificate checks, packet loss, latency, probe health, incidents, dashboards, and historical measurements so you can understand how a service behaves from different networks."
	},
	{
		question: "Why do I need probes I control?",
		answer:
			"Because third-party cloud checks cannot see every network that matters to you. A service may be reachable from a public monitoring region but degraded from your office, lab, ISP, edge node, private network, or user-facing environment. Netstamp gives you visibility from those real viewpoints."
	},
	{
		question: "Can I self-host Netstamp?",
		answer:
			"Yes. Netstamp is open-source and designed for self-hosted deployments with a controller, lightweight probes, PostgreSQL, TimescaleDB, health checks, metrics, OpenAPI, and production deployment documentation."
	},
	{
		question: "What can Netstamp monitor?",
		answer:
			"Netstamp supports real-world network checks such as ping, TCP, traceroute, HTTP uptime, API payload checks, and TLS/SSL certificate monitoring. It also tracks probe health, latest measurements, incidents, dashboards, and historical trends."
	},
	{
		question: "Who is Netstamp for?",
		answer:
			"Netstamp is for developers, infrastructure teams, homelab users, SREs, network operators, researchers, and teams that need to observe services from machines, regions, ISPs, labs, edge nodes, private infrastructure, or real user-facing networks they control."
	},
	{
		question: "How does Netstamp help with debugging?",
		answer:
			"Netstamp helps you separate global outages from regional, provider-specific, probe-specific, target-specific, and route-specific problems. Historical measurements make it easier to see what changed, where it changed, and when it started."
	}
];
---

<section id="faq" class="faq" aria-labelledby="faq-title">
	<h2 id="faq-title">FAQ</h2>
	<div class="faq-list">
		{
			faqs.map((faq, index) => (
				<details class="faq-item" open={index === 0}>
					<summary>
						<span>{faq.question}</span>
						<span class="faq-toggle" aria-hidden="true" />
					</summary>
					<div class="faq-answer">
						<div>
							<p>{faq.answer}</p>
						</div>
					</div>
				</details>
			))
		}
	</div>

	<script>
		const animationKey = Symbol.for("netstamp.faqAnimation");

		function animateFaqDetails(root: ParentNode = document) {
			const details = root.querySelectorAll<HTMLDetailsElement>(".faq-item");
			for (const detail of details) {
				if (detail.dataset.faqBound === "true") continue;
				const summary = detail.querySelector("summary");
				const answer = detail.querySelector<HTMLElement>(".faq-answer");
				if (!summary || !answer) continue;

				detail.dataset.faqBound = "true";
				summary.addEventListener("click", event => {
					event.preventDefault();
					const animation = (detail as HTMLDetailsElement & { [animationKey]?: Animation })[animationKey];
					animation?.cancel();

					if (detail.open) {
						const startHeight = answer.offsetHeight;
						const closing = answer.animate(
							[
								{ height: `${startHeight}px`, opacity: 1 },
								{ height: "0px", opacity: 0 }
							],
							{
								duration: 260,
								easing: "cubic-bezier(0.2, 0.8, 0.2, 1)"
							}
						);
						(detail as HTMLDetailsElement & { [animationKey]?: Animation })[animationKey] = closing;
						closing.onfinish = () => {
							detail.open = false;
							answer.style.height = "";
							answer.style.opacity = "";
							(detail as HTMLDetailsElement & { [animationKey]?: Animation })[animationKey] = undefined;
						};
						return;
					}

					detail.open = true;
					const endHeight = answer.scrollHeight;
					const opening = answer.animate(
						[
							{ height: "0px", opacity: 0 },
							{ height: `${endHeight}px`, opacity: 1 }
						],
						{
							duration: 320,
							easing: "cubic-bezier(0.2, 0.8, 0.2, 1)"
						}
					);
					(detail as HTMLDetailsElement & { [animationKey]?: Animation })[animationKey] = opening;
					opening.onfinish = () => {
						answer.style.height = "";
						answer.style.opacity = "";
						(detail as HTMLDetailsElement & { [animationKey]?: Animation })[animationKey] = undefined;
					};
				});
			}
		}

		document.addEventListener("astro:page-load", () => animateFaqDetails());
		animateFaqDetails();
	</script>
</section>

<style>
	.faq {
		padding: 7.5rem clamp(1rem, 4vw, 4rem) 8rem;
		background: #f5f6f8;
		color: #000000;
	}

	h2 {
		max-width: 78rem;
		margin: 0 auto 2.5rem;
		font-family: "TASAExplorer", "TASA Explorer", "Inter", system-ui, sans-serif;
		font-size: 2.65rem;
		font-weight: 300;
		letter-spacing: 0;
		line-height: 1;
	}

	.faq-list {
		max-width: 78rem;
		margin: 0 auto;
		background-image: linear-gradient(90deg, #a1a7b2 0 2px, transparent 2px 12px);
		background-repeat: repeat-x;
		background-position: left top;
		background-size: 12px 2px;
	}

	.faq-item {
		background-image: linear-gradient(90deg, #a1a7b2 0 2px, transparent 2px 12px);
		background-repeat: repeat-x;
		background-position: left bottom;
		background-size: 12px 2px;
	}

	summary {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: center;
		gap: 2.25rem;
		min-height: 8.5rem;
		padding: 2.15rem 0;
		cursor: pointer;
		list-style: none;
	}

	summary::-webkit-details-marker {
		display: none;
	}

	summary > span:first-child {
		font-family: "TASAExplorer", "TASA Explorer", "Inter", system-ui, sans-serif;
		font-size: 3.1rem;
		font-weight: 300;
		letter-spacing: 0;
		line-height: 1.05;
	}

	.faq-toggle {
		position: relative;
		display: grid;
		place-items: center;
		width: 4rem;
		height: 4rem;
		background: var(--home-orange-hot);
		transition: transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1);
	}

	.faq-toggle::before,
	.faq-toggle::after {
		content: "";
		position: absolute;
		width: 1.65rem;
		height: 0.18rem;
		background: #ffffff;
	}

	.faq-toggle::after {
		transform: rotate(90deg);
	}

	.faq-item[open] .faq-toggle {
		transform: rotate(45deg);
	}

	.faq-answer {
		overflow: hidden;
	}

	.faq-answer > div {
		padding-bottom: 2.35rem;
	}

	.faq-answer p {
		max-width: 58rem;
		margin: -0.65rem 0 0;
		color: #405168;
		font-size: 1.05rem;
		line-height: 1.65;
	}

	@media (min-width: 86rem) {
		h2 {
			font-size: 3.35rem;
		}

		summary > span:first-child {
			font-size: 4.1rem;
		}
	}

	@media (max-width: 52rem) {
		h2 {
			font-size: 2.65rem;
		}

		summary {
			min-height: 6.5rem;
			gap: 1.25rem;
			padding: 1.6rem 0;
		}

		summary > span:first-child {
			font-size: 2.1rem;
		}

		.faq-toggle {
			width: 3.25rem;
			height: 3.25rem;
		}
	}

	@media (max-width: 36rem) {
		.faq {
			padding: 5.5rem 1rem 6rem;
		}

		summary > span:first-child {
			font-size: 1.7rem;
		}

		.faq-toggle {
			width: 2.75rem;
			height: 2.75rem;
		}

		.faq-answer > div {
			padding-bottom: 1.75rem;
		}
	}
</style>
