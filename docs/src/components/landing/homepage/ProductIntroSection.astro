---
import { uiForLocale } from "../../../i18n/ui";

const ui = uiForLocale(Astro.currentLocale);
---

<section id="product-intro" class="intro" data-scroll-progress="intro" aria-label={ui.home.introAria}>
	<p class="intro-copy">
		{ui.home.introBefore}{" "}
		<span class="intro-mark" data-intro-highlight>
			<span class="intro-mark-base">{ui.home.latency}</span>
			<span class="intro-mark-fill" aria-hidden="true"><span class="intro-icon"><ph-pulse weight="regular" focusable="false"></ph-pulse></span><span>{ui.home.latency}</span></span>
		</span>{ui.home.listSeparator}
		<span class="intro-mark" data-intro-highlight>
			<span class="intro-mark-base">{ui.home.packetLoss}</span>
			<span class="intro-mark-fill" aria-hidden="true"><span class="intro-icon"><ph-warning weight="regular" focusable="false"></ph-warning></span><span>{ui.home.packetLoss}</span></span>
		</span>{ui.home.listSeparator}
		<span class="intro-mark" data-intro-highlight>
			<span class="intro-mark-base">{ui.home.routes}</span>
			<span class="intro-mark-fill" aria-hidden="true"><span class="intro-icon"><ph-git-branch weight="regular" focusable="false"></ph-git-branch></span><span>{ui.home.routes}</span></span>
		</span>{ui.home.listSeparator}
		<span class="intro-mark" data-intro-highlight>
			<span class="intro-mark-base">{ui.home.uptime}</span>
			<span class="intro-mark-fill" aria-hidden="true"><span class="intro-icon"><ph-check-circle weight="regular" focusable="false"></ph-check-circle></span><span>{ui.home.uptime}</span></span>
		</span>{ui.home.listSeparator}
		<span class="intro-mark" data-intro-highlight>
			<span class="intro-mark-base">{ui.home.certificates}</span>
			<span class="intro-mark-fill" aria-hidden="true"><span class="intro-icon"><ph-shield-check weight="regular" focusable="false"></ph-shield-check></span><span>{ui.home.certificates}</span></span>
		</span>{ui.home.introAfterSeparator}{ui.home.introAfter}
	</p>
</section>

<style>
	.intro {
		display: grid;
		align-items: center;
		padding: 0 clamp(1rem, 5vw, 5rem) 14svh;
		background: var(--ns-chrome-text);
		color: var(--ns-bg);
	}

	.intro-copy {
		max-width: 108rem;
		margin: 0 auto;
		font-family: var(--ns-font-title);
		font-size: 3rem;
		font-weight: 300;
		letter-spacing: 0;
		line-height: 1.03;
	}

	.intro-mark {
		--highlight-clip: 0%;
		--intro-highlight-height: 1em;
		position: relative;
		display: inline-block;
		vertical-align: -0.17em;
		white-space: nowrap;
	}

	.intro-mark-base,
	.intro-mark-fill {
		display: inline-flex;
		align-items: center;
		gap: 0;
		padding: 0;
		height: var(--intro-highlight-height);
		line-height: 1;
	}

	.intro-mark-base {
		color: var(--ns-bg);
	}

	.intro-mark-base::before {
		content: "";
		display: block;
		flex: 0 0 auto;
		width: var(--intro-highlight-height);
		height: var(--intro-highlight-height);
	}

	.intro-mark-fill {
		position: absolute;
		inset: 0;
		overflow: hidden;
		color: var(--ns-chrome-text);
		clip-path: inset(0 var(--highlight-clip) 0 0);
		pointer-events: none;
		user-select: none;
		will-change: clip-path;
	}

	.intro-icon {
		display: grid;
		flex: 0 0 auto;
		place-items: center;
		width: var(--intro-highlight-height);
		height: var(--intro-highlight-height);
		color: var(--ns-chrome-text);
		background: var(--ns-primary-active);
	}

	.intro-mark-fill > span:last-child {
		display: inline-flex;
		align-items: center;
		height: var(--intro-highlight-height);
		background: var(--ns-bg);
		line-height: 1;
	}

	.intro-icon :global(.icon),
	.intro-icon :global(ph-pulse),
	.intro-icon :global(ph-warning),
	.intro-icon :global(ph-git-branch),
	.intro-icon :global(ph-check-circle),
	.intro-icon :global(ph-shield-check) {
		width: 0.55em;
		height: 0.55em;
	}

	@media (min-width: 48rem) {
		.intro-copy {
			font-size: 4.4rem;
			line-height: 1.04;
		}
	}

	@media (min-width: 76rem) {
		.intro-copy {
			font-size: 5.45rem;
		}
	}

	@media (min-width: 96rem) {
		.intro-copy {
			font-size: 6.25rem;
		}
	}

	@media (max-width: 38rem) {
		.intro-copy {
			font-size: 2.65rem;
			line-height: 1.08;
		}
	}
</style>
