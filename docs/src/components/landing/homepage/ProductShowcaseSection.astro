---
import dashboardLight from "../../../assets/homepage-dashboard-light.png?url";

const items = [
	{
		title: "Ping latency",
		description: "See round-trip time and packet loss from each probe."
	},
	{
		title: "HTTP uptime",
		description: "Measure whether your services respond correctly from real networks."
	},
	{
		title: "TCP reachability",
		description: "Verify whether ports are reachable before users report timeouts."
	},
	{
		title: "Traceroute paths",
		description: "Understand how traffic moves, where routes change, and where paths degrade."
	},
	{
		title: "TLS certificates",
		description: "Track certificate validity before expired certificates become incidents."
	},
	{
		title: "Probe health",
		description: "Know which viewpoints are reporting, degraded, offline, or misconfigured."
	},
	{
		title: "Incidents",
		description: "Group abnormal behavior into actionable network events."
	},
	{
		title: "Historical trends",
		description: "Keep long-term measurements in PostgreSQL and TimescaleDB for debugging, reporting, and postmortems."
	}
];
---

<section id="green-dot" class="showcase" aria-labelledby="green-dot-title">
	<header>
		<h2 id="green-dot-title">A green dot is not enough.</h2>
		<p>Netstamp let you see the real status, finding the real problem.</p>
	</header>
	<div class="showcase-grid">
		<div class="feature-gallery" aria-label="Netstamp evidence gallery">
			{
				items.map(item => (
					<article>
						<h3>{item.title}</h3>
						<p>{item.description}</p>
					</article>
				))
			}
		</div>
		<figure class="dashboard-shot">
			<img src={dashboardLight} alt="Netstamp dashboard showing probe count, active checks, and map-based network viewpoints" loading="eager" decoding="async" />
		</figure>
	</div>
</section>

<style>
	.showcase {
		padding: 7.5rem clamp(1rem, 4vw, 4rem) 8.5rem;
		background: #ffffff;
		color: #000000;
	}

	header {
		max-width: 88rem;
		margin: 0 auto 3rem;
	}

	h2 {
		margin: 0;
		font-family: "TASAExplorer", "TASA Explorer", "Inter", system-ui, sans-serif;
		font-size: 4.4rem;
		font-weight: 300;
		letter-spacing: 0;
		line-height: 0.98;
	}

	header p {
		max-width: 42rem;
		margin: 2rem 0 0;
		color: #3f4b5c;
		font-size: 1.2rem;
		line-height: 1.55;
	}

	.showcase-grid {
		display: grid;
		grid-template-columns: minmax(20rem, 0.88fr) minmax(0, 1.45fr);
		gap: 1.25rem;
		align-items: stretch;
		max-width: 88rem;
		margin: 0 auto;
	}

	.feature-gallery {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
	}

	article {
		display: grid;
		align-content: start;
		min-height: 8.75rem;
		padding: 1rem;
		border: 1px solid #111111;
		background: #ffffff;
	}

	article::before {
		content: "";
		width: 0.7rem;
		height: 0.7rem;
		margin-bottom: 0.85rem;
		background: var(--home-orange-hot);
	}

	h3 {
		margin: 0;
		font-family: var(--ns-font-mono);
		font-size: 0.88rem;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	article p {
		margin: 0.65rem 0 0;
		color: #526176;
		font-size: 0.9rem;
		line-height: 1.45;
	}

	.dashboard-shot {
		position: relative;
		display: grid;
		min-width: 0;
		margin: 0;
		border: 1px solid #111111;
		background: linear-gradient(90deg, rgba(249, 115, 22, 0.18) 0 1px, transparent 1px 100%), linear-gradient(180deg, rgba(249, 115, 22, 0.18) 0 1px, transparent 1px 100%), #f4f5f7;
		background-size: 4rem 4rem;
	}

	.dashboard-shot::before {
		content: "";
		position: absolute;
		top: 1rem;
		right: 1rem;
		width: 1.25rem;
		height: 1.25rem;
		background: var(--home-orange-hot);
		box-shadow:
			-1.75rem 0 0 #000000,
			-3.5rem 0 0 #ffffff;
	}

	img {
		width: 100%;
		height: 100%;
		min-height: 32rem;
		object-fit: cover;
		object-position: left top;
		padding: 3rem 1.5rem 1.5rem;
	}

	@media (min-width: 86rem) {
		h2 {
			font-size: 5.8rem;
		}
	}

	@media (max-width: 72rem) {
		.showcase-grid {
			grid-template-columns: 1fr;
		}

		img {
			min-height: 26rem;
		}
	}

	@media (max-width: 42rem) {
		.showcase {
			padding: 5.5rem 1rem 6rem;
		}

		h2 {
			font-size: 3rem;
		}

		header p {
			font-size: 1rem;
		}

		.feature-gallery {
			grid-template-columns: 1fr;
		}

		article {
			min-height: auto;
		}

		img {
			min-height: 18rem;
			padding: 2.5rem 0.75rem 0.75rem;
		}
	}
</style>
