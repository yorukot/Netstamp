---
import { localeFromAstro, pathForLocale, uiForLocale } from "../i18n/ui";
import BaseLayout from "../layouts/BaseLayout.astro";

const locale = localeFromAstro(Astro.currentLocale);
const ui = uiForLocale(locale);
---

<BaseLayout title={ui.notFound.metaTitle} description={ui.notFound.description} canonicalPath="/404.html" navigationPath="/404.html" noindex>
	<main id="content" class="notFoundPage">
		<p class="notFoundCode" aria-hidden="true">404</p>
		<h1>{ui.notFound.title}</h1>
		<p class="notFoundDescription">{ui.notFound.description}</p>
		<div class="notFoundActions">
			<a class="notFoundPrimaryAction" href={pathForLocale("/", locale)}>{ui.notFound.home}</a>
			<a class="notFoundSecondaryAction" href={pathForLocale("/docs/", locale)}>{ui.notFound.docs}</a>
		</div>
	</main>
</BaseLayout>

<style>
	.notFoundPage {
		display: grid;
		align-content: center;
		justify-items: center;
		min-height: 100svh;
		padding: 8rem clamp(1.5rem, 5vw, 4rem) 4rem;
		color: var(--ns-text);
		background: var(--ns-bg);
		text-align: center;
	}

	.notFoundCode {
		margin: 0 0 1rem;
		color: var(--ns-primary);
		font-family: var(--ns-font-code);
		font-size: 1rem;
		font-weight: 750;
		letter-spacing: 0.2em;
	}

	h1 {
		margin: 0;
		font-size: clamp(2.5rem, 8vw, 5rem);
		line-height: 1;
	}

	.notFoundDescription {
		max-width: 42rem;
		margin: 1.5rem 0 0;
		color: var(--ns-text-muted);
		font-size: 1.0625rem;
		line-height: 1.7;
	}

	.notFoundActions {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.75rem;
		margin-top: 2rem;
	}

	.notFoundPrimaryAction,
	.notFoundSecondaryAction {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.75rem;
		padding: 0.625rem 1rem;
		border: 1px solid var(--ns-border);
		font-weight: 700;
		text-decoration: none;
	}

	.notFoundPrimaryAction {
		border-color: var(--ns-primary);
		color: var(--ns-text-on-accent);
		background: var(--ns-primary);
	}

	.notFoundSecondaryAction {
		color: var(--ns-text);
		background: var(--ns-surface);
	}

	.notFoundPrimaryAction:hover,
	.notFoundSecondaryAction:hover {
		border-color: var(--ns-primary-hover);
	}

	.notFoundPrimaryAction:focus-visible,
	.notFoundSecondaryAction:focus-visible {
		outline: var(--ns-focus-outline);
		outline-offset: var(--ns-focus-outline-offset);
	}
</style>
