---
import Icon from "../components/icons/Icon.astro";
import SearchBox from "../components/docs/SearchBox.astro";
import chatGptLogoUrl from "../assets/logos/ChatGPT.svg?url";
import claudeLogoUrl from "../assets/logos/Claude.svg?url";
import { docsNav, docsPages, githubBaseUrl } from "../data/docs";
import { absoluteUrl, createBreadcrumbSchema, createTechArticleSchema, resolveSiteUrl, type HeadEntry } from "../lib/seo";
import BaseLayout from "./BaseLayout.astro";
import { Button } from "@netstamp/ui";

interface Heading {
	depth: 2 | 3;
	slug: string;
	text: string;
}

interface Props {
	title?: string;
	description?: string;
	headings?: Heading[];
	editPath?: string;
	head?: HeadEntry[];
	frontmatter?: {
		title?: string;
		description?: string;
		editPath?: string;
		head?: HeadEntry[];
	};
}

const frontmatter = Astro.props.frontmatter ?? {};
const title = Astro.props.title ?? frontmatter.title ?? "Docs";
const description = Astro.props.description ?? frontmatter.description ?? "Netstamp documentation.";
const head = Astro.props.head ?? frontmatter.head ?? [];
const browserTitle = head.find(entry => entry.tag === "title")?.content ?? `${title} - Netstamp Docs`;
const extraHead = head.filter(entry => entry.tag !== "title");
const markdownHeadings = Astro.props.headings?.filter((heading): heading is Heading => heading.depth === 2 || heading.depth === 3) ?? [];
const headings = markdownHeadings;
const pathname = Astro.url.pathname.endsWith("/") ? Astro.url.pathname : `${Astro.url.pathname}/`;
const currentPageIndex = docsPages.findIndex(page => page.href === pathname);
const currentPage = currentPageIndex >= 0 ? docsPages[currentPageIndex] : undefined;
const previousPage = currentPageIndex > 0 ? docsPages[currentPageIndex - 1] : undefined;
const nextPage = currentPageIndex >= 0 && currentPageIndex < docsPages.length - 1 ? docsPages[currentPageIndex + 1] : undefined;
const editPath = Astro.props.editPath ?? frontmatter.editPath ?? currentPage?.editPath ?? Astro.url.pathname;
const editUrl = `${githubBaseUrl}/${editPath}`;
const siteUrl = resolveSiteUrl(Astro.site);
const pageUrl = absoluteUrl(pathname, siteUrl);
const breadcrumbs =
	pathname === "/docs/"
		? [
				{ name: "Netstamp", url: siteUrl },
				{ name: "Docs", url: pageUrl }
			]
		: [
				{ name: "Netstamp", url: siteUrl },
				{ name: "Docs", url: absoluteUrl("/docs/", siteUrl) },
				{ name: title, url: pageUrl }
			];
const schema = [createBreadcrumbSchema(breadcrumbs), createTechArticleSchema(siteUrl, pageUrl, title, description)];
const pageAssistantPrompt = `Please read and explain this documentation page: ${pageUrl}

Please provide a clear summary and help me understand the key concepts covered in this documentation.`;
const chatGptUrl = `https://chatgpt.com/?q=${encodeURIComponent(pageAssistantPrompt)}`;
const claudeUrl = `https://claude.ai/new?q=${encodeURIComponent(pageAssistantPrompt)}`;

function isActiveNavItem(href: string) {
	return pathname === href || (href !== "/docs/" && pathname.startsWith(href));
}

const navGroups = docsNav.map(group => ({
	...group,
	id: group.title.toLowerCase().replace(/[^a-z0-9]+/g, "-"),
	active: group.items.some(item => isActiveNavItem(item.href)),
	items: group.items.map(item => ({
		...item,
		active: isActiveNavItem(item.href),
		depth: Math.max(0, item.href.split("/").filter(Boolean).length - 2)
	}))
}));
const currentGroup = navGroups.find(group => group.active);
const visibleBreadcrumbs =
	pathname === "/docs/"
		? [{ name: "Docs home", href: "/docs/", current: true, icon: "home" as const }]
		: [
				{ name: "Docs home", href: "/docs/", current: false, icon: "home" as const },
				currentGroup ? { name: currentGroup.title, href: currentGroup.items[0]?.href ?? "/docs/", current: false } : undefined,
				{ name: title, href: pathname, current: true }
			].filter((item): item is { name: string; href: string; current: boolean; icon?: "home" } => Boolean(item));
---

<BaseLayout title={browserTitle} description={description} head={extraHead} canonicalPath={pathname} ogType="article" schema={schema}>
	<div class="docsShell" data-docs-shell>
		<aside class="docsSidebar" aria-label="Documentation navigation">
			<div class="docsSidebarHeader">
				<SearchBox />
				<Button className="docsMobileNavToggle" variant="outline" size="sm" type="button" data-docs-mobile-nav-toggle aria-expanded="false" aria-controls="docs-nav-tree">
					<span>
						<Icon name="toc" size={16} />
						Navigation
					</span>
					<Icon name="caret" size={12} />
				</Button>
			</div>
			<nav class="docsNavTree" id="docs-nav-tree" data-docs-nav-panel data-state="closed">
				{
					navGroups.map(group => (
						<section class:list={["docsNavSection", group.active && "active"]} aria-labelledby={`docs-nav-section-${group.id}`}>
							<h2 class="docsNavSectionTitle" id={`docs-nav-section-${group.id}`}>
								{group.title}
							</h2>
							<div class="docsNavSectionItems">
								{group.items.map(item => (
									<a href={item.href} class:list={["docsNavItem", item.active && "active"]} aria-current={item.active ? "page" : undefined} title={item.title} style={`--nav-depth: ${item.depth};`}>
										<span>{item.title}</span>
									</a>
								))}
							</div>
						</section>
					))
				}
			</nav>
		</aside>

		<main id="content" class="docContent">
			<header class="docHeader">
				<nav class="docBreadcrumb" aria-label="Breadcrumb">
					<ol>
						{
							visibleBreadcrumbs.map((item, index) => (
								<li>
									{item.current ? (
										<span aria-current="page" title={item.name}>
											{item.icon ? <Icon name={item.icon} size={14} /> : item.name}
										</span>
									) : (
										<a href={item.href} title={item.name} aria-label={item.icon ? item.name : undefined}>
											{item.icon ? <Icon name={item.icon} size={14} /> : item.name}
										</a>
									)}
									{index < visibleBreadcrumbs.length - 1 && (
										<span class="docBreadcrumbSeparator" aria-hidden="true">
											<Icon name="caretRight" size={12} />
										</span>
									)}
								</li>
							))
						}
					</ol>
				</nav>
				<h1>{title}</h1>
				<p>{description}</p>
			</header>
			<article class="docProse">
				<slot />
			</article>
			<footer class="docFooter">
				<a class="editLink" href={editUrl} target="_blank" rel="noreferrer">
					<Icon name="edit" size={16} />
					Edit on GitHub
				</a>
				<nav class="docPager" aria-label="Documentation pagination">
					{
						previousPage ? (
							<a class="docPagerLink previous" href={previousPage.href}>
								<Icon name="arrowLeft" size={18} />
								<span>
									<small>Previous</small>
									<strong>{previousPage.title}</strong>
								</span>
							</a>
						) : (
							<span class="docPagerLink previous disabled" aria-disabled="true">
								<Icon name="arrowLeft" size={18} />
								<span>
									<small>Previous</small>
									<strong>No previous page</strong>
								</span>
							</span>
						)
					}
					{
						nextPage ? (
							<a class="docPagerLink next" href={nextPage.href}>
								<span>
									<small>Next</small>
									<strong>{nextPage.title}</strong>
								</span>
								<Icon name="arrowRight" size={18} />
							</a>
						) : (
							<span class="docPagerLink next disabled" aria-disabled="true">
								<span>
									<small>Next</small>
									<strong>No next page</strong>
								</span>
								<Icon name="arrowRight" size={18} />
							</span>
						)
					}
				</nav>
			</footer>
		</main>

		<aside class="docsToc" aria-label="On this page">
			<div class="docsTocInner">
				<div class="docsPageActions" data-docs-page-actions>
					<Button className="docsPageActionsToggle" variant="ghost" size="sm" type="button" data-docs-page-actions-toggle aria-expanded="false" aria-controls="docs-page-actions-menu">
						<Icon name="copy" size={16} />
						<span data-docs-action-label>Copy page</span>
						<Icon name="caret" size={12} />
					</Button>
					<div class="docsPageActionsMenu" id="docs-page-actions-menu" data-docs-page-actions-menu role="menu" hidden>
						<button class="docsPageActionItem" type="button" role="menuitem" data-docs-copy-page>
							<span class="docsPageActionIcon" aria-hidden="true">
								<Icon name="copy" size={18} />
							</span>
							<span class="docsPageActionCopy">
								<strong data-docs-action-label>Copy page</strong>
								<small>Copy the page as Markdown for LLMs</small>
							</span>
						</button>
						<button class="docsPageActionItem" type="button" role="menuitem" data-docs-view-markdown>
							<span class="docsPageActionIcon" aria-hidden="true">
								<Icon name="fileText" size={18} />
							</span>
							<span class="docsPageActionCopy">
								<strong>View as Markdown</strong>
								<small>View this page as plain text</small>
							</span>
						</button>
						<a class="docsPageActionItem" href={chatGptUrl} target="_blank" rel="noreferrer" role="menuitem">
							<span class="docsPageActionIcon" aria-hidden="true">
								<img class="docsPageActionLogo docsPageActionLogoChatGpt" src={chatGptLogoUrl} alt="" loading="lazy" />
							</span>
							<span class="docsPageActionCopy">
								<strong>Open in ChatGPT</strong>
								<small>Ask questions about this page</small>
							</span>
						</a>
						<a class="docsPageActionItem" href={claudeUrl} target="_blank" rel="noreferrer" role="menuitem">
							<span class="docsPageActionIcon" aria-hidden="true">
								<img class="docsPageActionLogo" src={claudeLogoUrl} alt="" loading="lazy" />
							</span>
							<span class="docsPageActionCopy">
								<strong>Open in Claude</strong>
								<small>Ask questions about this page</small>
							</span>
						</a>
					</div>
				</div>
				{
					headings.length ? (
						<nav data-docs-toc>
							{headings.map((heading, index) => (
								<a href={`#${heading.slug}`} data-toc-link class:list={[heading.depth === 3 && "sub", index === 0 && "active"]} aria-current={index === 0 ? "location" : undefined}>
									{heading.text}
								</a>
							))}
						</nav>
					) : (
						<p>No headings</p>
					)
				}
			</div>
		</aside>
	</div>

	<script>
		import "../scripts/docLayout";
	</script>

	<style>
		.docsShell {
			--docs-sticky-top: 6.25rem;
			display: grid;
			grid-template-columns: minmax(13rem, 15.5rem) minmax(0, 46rem) minmax(11rem, 14rem);
			justify-content: center;
			align-items: start;
			column-gap: clamp(1.5rem, 3vw, 3rem);
			min-height: 100svh;
			padding: 7.25rem clamp(1.25rem, 4vw, 3rem) 3rem;
			color: var(--ns-text);
			background: var(--ns-bg);
		}

		.docsNavItem:focus-visible,
		.docBreadcrumb a:focus-visible,
		.docPagerLink:focus-visible,
		.docsToc a:focus-visible,
		:global(.docsMobileNavToggle:focus-visible),
		:global(.editLink:focus-visible) {
			outline: var(--ns-focus-outline);
			outline-offset: 0.25rem;
		}

		.docsSidebar {
			position: sticky;
			top: var(--docs-sticky-top);
			align-self: start;
			max-height: calc(100svh - var(--docs-sticky-top) - 1.5rem);
			overflow: auto;
			scrollbar-gutter: stable;
		}

		.docsSidebar {
			display: grid;
			gap: 1rem;
			padding-bottom: 1rem;
		}

		.docsToc {
			min-width: 0;
		}

		.docsTocInner {
			position: fixed;
			top: var(--docs-sticky-top);
			width: min(14rem, 16vw);
			overflow: visible;
		}

		.docsSidebarHeader {
			display: grid;
			gap: 0.75rem;
		}

		:global(.docsMobileNavToggle) {
			--ns-frame-color: transparent;
			display: none;
			width: 100%;
			justify-content: space-between;
			gap: 0.75rem;
			padding: 0.55rem 0.7rem;
			color: var(--ns-text-muted);
			background: var(--ns-bg-subtle);
			font-family: var(--ns-font-mono);
			font-size: 0.68rem;
			font-weight: 800;
			letter-spacing: 0.1em;
			text-transform: uppercase;
		}

		:global(.docsMobileNavToggle span) {
			display: inline-flex;
			align-items: center;
			gap: 0.45rem;
		}

		:global(.docsMobileNavToggle:hover),
		:global(.docsMobileNavToggle[aria-expanded="true"]) {
			--ns-frame-color: transparent;
			color: var(--ns-text);
			background: var(--ns-primary-muted);
		}

		:global(.docsMobileNavToggle[aria-expanded="true"] > .icon:last-child) {
			transform: rotate(180deg);
		}

		:global(.icon) {
			flex: 0 0 auto;
		}

		.docsNavSectionTitle {
			display: inline-flex;
			align-items: center;
			gap: 0.45rem;
			color: var(--ns-text-low);
			font-family: var(--ns-font-mono);
			font-size: 0.68rem;
			font-weight: 800;
			letter-spacing: 0.12em;
			text-transform: uppercase;
		}

		.docsNavTree {
			display: grid;
			gap: 1.25rem;
		}

		.docsNavSection {
			display: grid;
			gap: 0.45rem;
		}

		.docsNavSectionItems {
			display: grid;
			gap: 0.125rem;
		}

		.docsNavItem {
			position: relative;
			display: block;
			padding: 0.42rem 0.5rem 0.42rem calc(0.55rem + (var(--nav-depth, 0) * 0.8rem));
			color: var(--ns-text-subtle);
			border-left: 2px solid transparent;
			font-size: 0.9rem;
			line-height: 1.35;
			text-decoration: none;
			transition:
				border-color var(--ns-transition),
				background var(--ns-transition),
				color var(--ns-transition);
		}

		.docsNavItem:hover,
		.docsNavItem.active {
			color: var(--ns-primary-hover);
			background: var(--ns-primary-muted);
		}

		.docsNavItem.active {
			border-left-color: var(--ns-primary);
			color: var(--ns-text);
			font-weight: 700;
		}

		.docsNavItem span {
			display: block;
			overflow: hidden;
			text-overflow: ellipsis;
			white-space: nowrap;
		}

		.docContent {
			min-width: 0;
			display: grid;
			gap: 1.75rem;
			align-self: start;
		}

		.docHeader {
			display: grid;
			gap: 0.875rem;
			padding: 0.25rem 0 0.5rem;
		}

		.docBreadcrumb {
			margin-bottom: 0.45rem;
		}

		.docBreadcrumb ol {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			gap: 0.35rem;
			margin: 0;
			padding: 0;
			list-style: none;
		}

		.docBreadcrumb li {
			display: inline-flex;
			align-items: center;
			gap: 0.35rem;
			min-width: 0;
		}

		.docBreadcrumb a,
		.docBreadcrumb span {
			display: inline-flex;
			align-items: center;
			min-width: 0;
			overflow: hidden;
			color: var(--ns-text-low);
			font-family: var(--ns-font-mono);
			font-size: 0.72rem;
			font-weight: 500;
			letter-spacing: 0.09em;
			text-decoration: none;
			text-overflow: ellipsis;
			text-transform: uppercase;
			white-space: nowrap;
		}

		.docBreadcrumb a:hover,
		.docBreadcrumb span {
			color: var(--ns-primary-hover);
		}

		.docBreadcrumb .docBreadcrumbSeparator {
			color: var(--ns-text-low);
			opacity: 0.8;
		}

		.docHeader h1 {
			max-width: 20ch;
			margin: 0;
			font-family: var(--ns-font-display);
			font-size: clamp(2.1rem, 4vw, 3.25rem);
			font-weight: 850;
			letter-spacing: 0;
			line-height: 1.02;
		}

		.docHeader p {
			max-width: 58ch;
			margin: 0;
			color: var(--ns-text-muted);
			font-size: 1.06rem;
			line-height: 1.72;
		}

		:global(.editLink) {
			--ns-frame-color: transparent;
			display: inline-flex;
			align-items: center;
			gap: 0.45rem;
			width: fit-content;
			margin-bottom: 1rem;
			padding: 0;
			color: var(--ns-primary);
			background: transparent;
			font-family: var(--ns-font-mono);
			font-size: 0.75rem;
			font-weight: 800;
			letter-spacing: 0.08em;
			text-decoration: none;
			text-transform: uppercase;
		}

		:global(.editLink:hover) {
			--ns-frame-color: transparent;
			color: var(--ns-primary-hover);
			background: transparent;
			text-decoration: underline;
			text-underline-offset: 0.18em;
		}

		.docProse {
			display: grid;
			gap: 1.35rem;
			padding: 0 0 0.5rem;
		}

		.docFooter {
			display: grid;
			gap: 1rem;
			padding: 0 0 5rem;
		}

		.docPager {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 1rem;
		}

		.docPagerLink {
			display: flex;
			align-items: center;
			gap: 0.75rem;
			min-height: 4.5rem;
			padding: 0.9rem;
			color: var(--ns-text-subtle);
			border: 1px solid color-mix(in srgb, var(--ns-border-faint) 72%, transparent);
			text-decoration: none;
			transition:
				border-color var(--ns-transition),
				color var(--ns-transition),
				transform var(--ns-transition);
		}

		.docPagerLink.next {
			justify-content: flex-end;
			text-align: right;
		}

		.docPagerLink:hover {
			border-color: var(--ns-primary-border);
			color: var(--ns-primary-hover);
			transform: translateY(-1px);
		}

		.docPagerLink.disabled {
			color: var(--ns-text-low);
			transform: none;
		}

		.docPagerLink span {
			display: grid;
			gap: 0.25rem;
			min-width: 0;
		}

		.docPagerLink small {
			color: var(--ns-text-low);
			font-family: var(--ns-font-mono);
			font-size: 0.68rem;
			font-weight: 800;
			letter-spacing: 0.12em;
			text-transform: uppercase;
		}

		.docPagerLink strong {
			overflow: hidden;
			color: inherit;
			font-family: var(--ns-font-mono);
			font-size: 0.86rem;
			letter-spacing: 0.04em;
			text-overflow: ellipsis;
			text-transform: uppercase;
			white-space: nowrap;
		}

		:global(.docProse h2),
		:global(.docProse h3) {
			scroll-margin-top: 6rem;
			margin: 0;
			color: var(--ns-text);
			font-family: var(--ns-font-display);
			letter-spacing: 0;
		}

		:global(.docProse h2) {
			font-size: clamp(1.55rem, 3vw, 2.25rem);
			line-height: 1.08;
		}

		:global(.docProse h3) {
			font-size: clamp(1.15rem, 2vw, 1.45rem);
		}

		:global(.docProse p),
		:global(.docProse li) {
			color: var(--ns-text-muted);
			font-size: 1rem;
			line-height: 1.75;
		}

		:global(.docProse p),
		:global(.docProse ul),
		:global(.docProse ol) {
			margin: 0;
		}

		:global(.docProse ul),
		:global(.docProse ol) {
			display: grid;
			gap: 0.45rem;
			padding-left: 1.2rem;
		}

		:global(.docProse a) {
			color: var(--ns-primary-hover);
		}

		:global(.docProse code:not(pre code)) {
			padding: 0.1rem 0.28rem;
			color: var(--ns-primary-hover);
			background: var(--ns-primary-muted);
			font-family: var(--ns-font-mono);
			font-size: 0.9em;
		}

		:global(.docProse > pre),
		:global(.docProse > .astro-code) {
			position: relative;
			padding: 2.5rem 1.25rem 1.125rem !important;
			background-color: var(--ns-surface-deep) !important;
			overflow-x: auto !important;
			border: 1px solid var(--ns-border);
			box-shadow: none;
		}

		:global(.docProse > pre::before),
		:global(.docProse > .astro-code::before) {
			content: "";
			position: absolute;
			top: 0;
			left: 0;
			right: 0;
			height: 2.25rem;
			background: var(--ns-surface-raised);
			border-bottom: 1px solid var(--ns-border-faint);
		}

		:global(.docProse blockquote) {
			display: grid;
			gap: 0.5rem;
			margin: 0;
			padding: 1rem;
			border: 0;
			border-left: 2px solid var(--ns-primary);
			background: var(--ns-primary-muted);
		}

		:global(.docProse blockquote strong) {
			color: var(--ns-primary-hover);
			font-family: var(--ns-font-mono);
			font-size: 0.75rem;
			font-weight: 900;
			letter-spacing: 0.1em;
			text-transform: uppercase;
		}

		:global(.callout) {
			display: grid;
			gap: 0.6rem;
			padding: 1rem;
			border: 0;
			border-left: 2px solid var(--ns-border);
			background: var(--ns-surface);
		}

		:global(.calloutTitle) {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			font-family: var(--ns-font-mono);
			font-size: 0.75rem;
			font-weight: 900;
			letter-spacing: 0.1em;
			text-transform: uppercase;
		}

		:global(.calloutTitle [data-callout-icon]) {
			flex: 0 0 auto;
			color: currentcolor;
		}

		:global(.calloutBody) {
			display: grid;
