---
import faviconUrl from "@netstamp/brand/assets/netstamp-favicon.svg?url";
import { localeMetadata, stripLocalePrefix } from "@netstamp/i18n";
import "@netstamp/ui/styles";
import { ClientRouter } from "astro:transitions";
import TopNav from "../components/docs/TopNav.astro";
import TrackingConsent from "../components/tracking/TrackingConsent.astro";
import { localeFromAstro, pathForLocale, uiForLocale } from "../i18n/ui";
import { absoluteUrl, createPageSeoHead, createSchemaGraph, resolveSiteUrl, type HeadEntry } from "../lib/seo";

interface Props {
	title: string;
	description?: string;
	nav?: boolean;
	bodyClass?: string;
	fixedTheme?: "dark" | "light";
	head?: HeadEntry[];
	canonicalPath?: string;
	navigationPath?: string;
	ogType?: "article" | "website";
	noindex?: boolean;
	schema?: Record<string, unknown>[];
}

const locale = localeFromAstro(Astro.currentLocale);
const ui = uiForLocale(locale);
const { title, description = ui.meta.description, nav = true, bodyClass, fixedTheme, head = [], canonicalPath, navigationPath, ogType = "website", noindex = false, schema = [] } = Astro.props;
const siteUrl = resolveSiteUrl(Astro.site);
const localeNeutralPath = stripLocalePrefix(canonicalPath ?? Astro.url.pathname);
const localizedCanonicalPath = pathForLocale(localeNeutralPath, locale);
const canonicalUrl = absoluteUrl(localizedCanonicalPath, siteUrl);
const englishUrl = absoluteUrl(pathForLocale(localeNeutralPath, "en"), siteUrl);
const traditionalChineseUrl = absoluteUrl(pathForLocale(localeNeutralPath, "zh-TW"), siteUrl);
const imageUrl = absoluteUrl("/og.png", siteUrl);
const absoluteLogoUrl = absoluteUrl("/brand/netstamp-logo-light.svg", siteUrl);
const seoHead = createPageSeoHead({ title, description, canonicalUrl, imageUrl, ogType, noindex, locale });
const schemaGraph = createSchemaGraph({ title, description, pageUrl: canonicalUrl, siteUrl, logoUrl: absoluteLogoUrl, imageUrl, schemas: schema });
---

<!doctype html>
<html lang={localeMetadata[locale].htmlLang} data-theme-locked={fixedTheme}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={faviconUrl} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<script is:inline>
			(() => {
				const storageKey = "netstamp:theme";
				const isTheme = theme => theme === "light" || theme === "dark";
				const defaultTheme = "dark";

				const lockedTheme = document.documentElement.dataset.themeLocked;

				try {
					const storedTheme = window.localStorage.getItem(storageKey);
					const theme = isTheme(lockedTheme) ? lockedTheme : isTheme(storedTheme) ? storedTheme : defaultTheme;
					document.documentElement.classList.toggle("dark", theme === "dark");
					document.documentElement.dataset.theme = theme;
				} catch {
					const theme = isTheme(lockedTheme) ? lockedTheme : defaultTheme;
					document.documentElement.classList.toggle("dark", theme === "dark");
					document.documentElement.dataset.theme = theme;
				}
			})();
		</script>
		<title>{title}</title>
		<link rel="alternate" hreflang="en" href={englishUrl} />
		<link rel="alternate" hreflang="zh-TW" href={traditionalChineseUrl} />
		<link rel="alternate" hreflang="x-default" href={englishUrl} />
		{
			seoHead.map(entry => {
				const HeadTag = entry.tag;
				return entry.content ? <HeadTag {...entry.attrs}>{entry.content}</HeadTag> : <HeadTag {...entry.attrs} />;
			})
		}
		<script type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
		<ClientRouter />
		{
			head.map(entry => {
				const HeadTag = entry.tag;
				return entry.content ? <HeadTag {...entry.attrs}>{entry.content}</HeadTag> : <HeadTag {...entry.attrs} />;
			})
		}
	</head>
	<body class={bodyClass}>
		<script>
			import "../scripts/registerIcons";
		</script>
		<a class="skipLink" href="#content">{ui.common.skipToContent}</a>
		{nav ? <TopNav pathname={navigationPath} /> : null}
		<slot />
		<TrackingConsent />
		<script>
			import "../scripts/docsTheme";
		</script>
	</body>
</html>

<style is:global>
	.skipLink {
		position: fixed;
		top: 1rem;
		left: 1rem;
		z-index: var(--ns-z-skip-link);
		padding: 0.75rem 1rem;
		border: 1px solid var(--ns-border);
		color: var(--ns-text-on-accent);
		background: var(--ns-primary);
		font-weight: 700;
		line-height: 1;
		text-decoration: none;
		transform: translateY(-200%);
		transition: transform var(--ns-transition);
	}

	.skipLink:focus-visible {
		outline: var(--ns-focus-outline);
		outline-offset: var(--ns-focus-outline-offset);
		transform: translateY(0);
	}
</style>
