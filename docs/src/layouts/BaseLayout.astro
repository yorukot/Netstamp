---
import faviconUrl from "@netstamp/brand/assets/netstamp-favicon.svg?url";
import "@netstamp/ui/styles";
import { ClientRouter } from "astro:transitions";
import TopNav from "../components/docs/TopNav.astro";
import TrackingConsent from "../components/tracking/TrackingConsent.astro";
import { absoluteUrl, createPageSeoHead, createSchemaGraph, resolveSiteUrl, type HeadEntry } from "../lib/seo";

interface Props {
	title: string;
	description?: string;
	nav?: boolean;
	bodyClass?: string;
	head?: HeadEntry[];
	canonicalPath?: string;
	ogType?: "article" | "website";
	noindex?: boolean;
	schema?: Record<string, unknown>[];
}

const {
	title,
	description = "Open-source network observability from probes you control.",
	nav = true,
	bodyClass,
	head = [],
	canonicalPath,
	ogType = "website",
	noindex = false,
	schema = []
} = Astro.props;
const siteUrl = resolveSiteUrl(Astro.site);
const canonicalUrl = absoluteUrl(canonicalPath ?? Astro.url.pathname, siteUrl);
const imageUrl = absoluteUrl("/og.png", siteUrl);
const absoluteLogoUrl = absoluteUrl("/brand/netstamp-logo-light.svg", siteUrl);
const seoHead = createPageSeoHead({ title, description, canonicalUrl, imageUrl, ogType, noindex });
const schemaGraph = createSchemaGraph({ title, description, pageUrl: canonicalUrl, siteUrl, logoUrl: absoluteLogoUrl, imageUrl, schemas: schema });
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={faviconUrl} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<script is:inline>
			(() => {
				const storageKey = "netstamp:theme";
				const fallbackTheme = "light";

				try {
					const storedTheme = window.localStorage.getItem(storageKey);
					document.documentElement.dataset.theme = storedTheme === "light" || storedTheme === "dark" ? storedTheme : fallbackTheme;
				} catch {
					document.documentElement.dataset.theme = fallbackTheme;
				}
			})();
		</script>
		<title>{title}</title>
		{
			seoHead.map(entry => {
				const HeadTag = entry.tag;
				return entry.content ? <HeadTag {...entry.attrs}>{entry.content}</HeadTag> : <HeadTag {...entry.attrs} />;
			})
		}
		<script type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
		<ClientRouter />
		{
			head.map(entry => {
				const HeadTag = entry.tag;
				return entry.content ? <HeadTag {...entry.attrs}>{entry.content}</HeadTag> : <HeadTag {...entry.attrs} />;
			})
		}
	</head>
	<body class={bodyClass}>
		<script>
			import "../scripts/registerIcons";
		</script>
		{nav ? <TopNav /> : null}
		<slot />
		<TrackingConsent />
		<script>
			import "../scripts/docsTheme";
		</script>
	</body>
</html>
