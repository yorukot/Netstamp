---
import faviconUrl from "@netstamp/brand/assets/netstamp-favicon.svg?url";
import "@netstamp/ui/styles";
import { ClientRouter } from "astro:transitions";
import TopNav from "../components/docs/TopNav.astro";
import TrackingConsent from "../components/tracking/TrackingConsent.astro";
import { absoluteUrl, createPageSeoHead, createSchemaGraph, resolveSiteUrl, type HeadEntry } from "../lib/seo";
import "../styles/docs.css";

interface Props {
	title: string;
	description?: string;
	nav?: boolean;
	bodyClass?: string;
	head?: HeadEntry[];
	canonicalPath?: string;
	ogType?: "article" | "website";
	noindex?: boolean;
	schema?: Record<string, unknown>[];
}

const {
	title,
	description = "Open-source network observability from probes you control.",
	nav = true,
	bodyClass,
	head = [],
	canonicalPath,
	ogType = "website",
	noindex = false,
	schema = []
} = Astro.props;
const siteUrl = resolveSiteUrl(Astro.site);
const canonicalUrl = absoluteUrl(canonicalPath ?? Astro.url.pathname, siteUrl);
const imageUrl = absoluteUrl("/og.png", siteUrl);
const absoluteLogoUrl = absoluteUrl("/brand/netstamp-logo-light.svg", siteUrl);
const seoHead = createPageSeoHead({ title, description, canonicalUrl, imageUrl, ogType, noindex });
const schemaGraph = createSchemaGraph({ title, description, pageUrl: canonicalUrl, siteUrl, logoUrl: absoluteLogoUrl, imageUrl, schemas: schema });
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={faviconUrl} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<script is:inline>
			(() => {
				const storageKey = "netstamp:theme";
				const fallbackTheme = "light";

				try {
					const storedTheme = window.localStorage.getItem(storageKey);
					document.documentElement.dataset.theme = storedTheme === "light" || storedTheme === "dark" ? storedTheme : fallbackTheme;
				} catch {
					document.documentElement.dataset.theme = fallbackTheme;
				}
			})();
		</script>
		<title>{title}</title>
		{
			seoHead.map(entry => {
				const HeadTag = entry.tag;
				return entry.content ? <HeadTag {...entry.attrs}>{entry.content}</HeadTag> : <HeadTag {...entry.attrs} />;
			})
		}
		<script type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
		<ClientRouter />
		{
			head.map(entry => {
				const HeadTag = entry.tag;
				return entry.content ? <HeadTag {...entry.attrs}>{entry.content}</HeadTag> : <HeadTag {...entry.attrs} />;
			})
		}
	</head>
	<body class={bodyClass}>
		<script>
			import "@phosphor-icons/webcomponents/PhArrowLeft";
			import "@phosphor-icons/webcomponents/PhArrowRight";
			import "@phosphor-icons/webcomponents/PhArrowUpRight";
			import "@phosphor-icons/webcomponents/PhBookOpen";
			import "@phosphor-icons/webcomponents/PhCaretDown";
			import "@phosphor-icons/webcomponents/PhCheckCircle";
			import "@phosphor-icons/webcomponents/PhCode";
			import "@phosphor-icons/webcomponents/PhCompass";
			import "@phosphor-icons/webcomponents/PhCube";
			import "@phosphor-icons/webcomponents/PhDatabase";
			import "@phosphor-icons/webcomponents/PhFolderOpen";
			import "@phosphor-icons/webcomponents/PhGitBranch";
			import "@phosphor-icons/webcomponents/PhGithubLogo";
			import "@phosphor-icons/webcomponents/PhGlobeHemisphereWest";
			import "@phosphor-icons/webcomponents/PhHardDrives";
			import "@phosphor-icons/webcomponents/PhHouse";
			import "@phosphor-icons/webcomponents/PhKey";
			import "@phosphor-icons/webcomponents/PhLightbulb";
			import "@phosphor-icons/webcomponents/PhLightning";
			import "@phosphor-icons/webcomponents/PhListBullets";
			import "@phosphor-icons/webcomponents/PhMagnifyingGlass";
			import "@phosphor-icons/webcomponents/PhMapTrifold";
			import "@phosphor-icons/webcomponents/PhMoonStars";
			import "@phosphor-icons/webcomponents/PhNetwork";
			import "@phosphor-icons/webcomponents/PhNote";
			import "@phosphor-icons/webcomponents/PhPencilSimple";
			import "@phosphor-icons/webcomponents/PhPlugs";
			import "@phosphor-icons/webcomponents/PhPulse";
			import "@phosphor-icons/webcomponents/PhRocketLaunch";
			import "@phosphor-icons/webcomponents/PhShieldCheck";
			import "@phosphor-icons/webcomponents/PhSidebarSimple";
			import "@phosphor-icons/webcomponents/PhSun";
			import "@phosphor-icons/webcomponents/PhTerminalWindow";
			import "@phosphor-icons/webcomponents/PhUsers";
			import "@phosphor-icons/webcomponents/PhWarning";
			import "@phosphor-icons/webcomponents/PhWrench";
		</script>
		{nav ? <TopNav /> : null}
		<slot />
		<TrackingConsent />
		<script>
			const themeStorageKey = "netstamp:theme";
			let cleanupDocsTheme = () => {};

			function readDocsTheme() {
				const theme = document.documentElement.dataset.theme;
				return theme === "light" || theme === "dark" ? theme : "dark";
			}

			function writeDocsTheme(theme: "light" | "dark") {
				document.documentElement.dataset.theme = theme;

				try {
					window.localStorage.setItem(themeStorageKey, theme);
				} catch {
					// Persistence can be unavailable; keep the current page state usable.
				}
			}

			function initDocsTheme() {
				cleanupDocsTheme();

				const themeToggle = document.querySelector("[data-theme-toggle]");
				if (!themeToggle) return;

				function syncThemeToggle() {
					const theme = readDocsTheme();
					const nextTheme = theme === "dark" ? "light" : "dark";
					const label = nextTheme === "light" ? "Switch to light mode" : "Switch to dark mode";

					themeToggle.setAttribute("aria-label", label);
					themeToggle.setAttribute("title", label);
					themeToggle.setAttribute("aria-pressed", String(theme === "light"));
				}

				const handleThemeToggle = () => {
					writeDocsTheme(readDocsTheme() === "dark" ? "light" : "dark");
					syncThemeToggle();
				};

				syncThemeToggle();
				themeToggle.addEventListener("click", handleThemeToggle);
				cleanupDocsTheme = () => {
					themeToggle.removeEventListener("click", handleThemeToggle);
					cleanupDocsTheme = () => {};
				};
			}

			initDocsTheme();
			document.addEventListener("astro:page-load", initDocsTheme);
		</script>
	</body>
</html>
