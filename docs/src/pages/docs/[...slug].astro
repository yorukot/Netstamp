---
import DocPage from "../../components/docs/DocPage.astro";
import { getDocsPages } from "../../data/docs";

export async function getStaticPaths() {
	return getDocsPages("en")
		.filter(page => page.contentId !== "index")
		.map(page => ({ params: { slug: page.contentId }, props: { contentId: page.contentId } }));
}

const { contentId } = Astro.props;
---

<DocPage contentId={contentId} />
