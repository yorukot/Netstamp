---
import { render } from "astro:content";
import { Terminal } from "@netstamp/ui";
import { getIndexDoc } from "@/data/docs";
import { defaultLocale } from "@/i18n/config";
import DocLayout from "@/layouts/DocLayout.astro";

const doc = getIndexDoc(defaultLocale);

if (!doc) {
	throw new Error("Missing docs index content entry.");
}

const { Content, headings } = await render(doc.entry);
---

<DocLayout
	title={doc.entry.data.title}
	description={doc.entry.data.description}
	headings={headings}
	editPath={doc.editPath}
	head={doc.entry.data.head}
	locale={doc.locale}
	logicalPath={doc.logicalPath}
	isFallback={!doc.translated}
>
	<Content components={{ Terminal }} />
</DocLayout>
