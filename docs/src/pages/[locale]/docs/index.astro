---
import { render } from "astro:content";
import { Terminal } from "@netstamp/ui";
import { getIndexDoc, type ResolvedDoc } from "@/data/docs";
import { prefixedLocales } from "@/i18n/config";
import DocLayout from "@/layouts/DocLayout.astro";

export async function getStaticPaths() {
	return prefixedLocales
		.map(locale => {
			const doc = getIndexDoc(locale);
			return doc ? { params: { locale }, props: { doc } } : null;
		})
		.filter((route): route is { params: { locale: string }; props: { doc: ResolvedDoc } } => Boolean(route));
}

const { doc } = Astro.props as { doc: ResolvedDoc };
const { Content, headings } = await render(doc.entry);
---

<DocLayout
	title={doc.entry.data.title}
	description={doc.entry.data.description}
	headings={headings}
	editPath={doc.editPath}
	head={doc.entry.data.head}
	locale={doc.locale}
	logicalPath={doc.logicalPath}
	isFallback={!doc.translated}
>
	<Content components={{ Terminal }} />
</DocLayout>
