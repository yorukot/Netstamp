	"info": {
		"description": "Controller HTTP API for Netstamp.",
		"title": "Netstamp API",
		"version": "v1"
	},
	"openapi": "3.1.0",
	"paths": {
		"/": {
			"get": {
				"operationId": "getAPIStatus",
				"responses": {
					"200": {
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/RootBody"
								}
							}
						},
						"description": "OK"
					},
					"default": {
						"content": {
							"application/problem+json": {
								"schema": {
									"$ref": "#/components/schemas/ErrorModel"
								}
							}
						},
						"description": "Error"
					}
				},
				"summary": "Get API status",
				"tags": ["System"]
			}
		},
