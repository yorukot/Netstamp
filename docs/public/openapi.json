			"AddMemberInputBody": {
				"additionalProperties": false,
				"properties": {
					"$schema": {
						"description": "A URL to the JSON Schema for this object.",
						"examples": ["/api/v1/schemas/AddMemberInputBody.json"],
						"format": "uri",
						"readOnly": true,
						"type": "string"
					},
					"role": {
						"description": "Team member role.",
						"enum": ["owner", "admin", "editor", "viewer"],
						"examples": ["viewer"],
						"type": "string"
					},
					"userId": {
						"description": "User ID to add to the team.",
						"format": "uuid",
						"type": "string"
					}
				},
				"required": ["userId", "role"],
				"type": "object"
			},
			"CreateTeamInputBody": {
				"additionalProperties": false,
