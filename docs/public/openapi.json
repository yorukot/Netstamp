					"name": {
						"description": "Team display name.",
						"examples": ["Engineering"],
						"maxLength": 100,
						"minLength": 1,
						"type": "string"
					},
					"slug": {
						"description": "Stable team slug.",
						"examples": ["engineering"],
						"maxLength": 100,
						"minLength": 1,
						"pattern": "^[a-z0-9-]+$",
						"patternDescription": "lowercase letters, numbers, and dashes",
						"type": "string"
					}
				},
				"required": ["name", "slug"],
				"type": "object"
			},
			"ErrorDetail": {
				"additionalProperties": false,
				"properties": {
					"location": {
						"description": "Where the error occurred, e.g. 'body.items[3].tags' or 'path.thing-id'",
						"type": "string"
					},
					"message": {
						"description": "Error message text",
						"type": "string"
					},
					"value": {
						"description": "The value at the given location"
