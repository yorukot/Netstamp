# Optional public tracker IDs. Leave blank to disable each tracker.
PUBLIC_NETSTAMP_GA_MEASUREMENT_ID=
PUBLIC_NETSTAMP_GOOGLE_TAG_ID=
PUBLIC_NETSTAMP_CLARITY_PROJECT_ID=
PUBLIC_NETSTAMP_POSTHOG_KEY=
PUBLIC_NETSTAMP_POSTHOG_HOST=https://us.i.posthog.com
PUBLIC_NETSTAMP_PLAUSIBLE_DOMAIN=
PUBLIC_NETSTAMP_PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js
PUBLIC_NETSTAMP_UMAMI_WEBSITE_ID=
PUBLIC_NETSTAMP_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js

# Consent modes:
# - regional: ask only in configured countries, and ask when country is unknown.
# - always: ask every visitor before loading trackers.
# - never: load configured trackers without showing this banner.
PUBLIC_NETSTAMP_TRACKING_CONSENT_MODE=regional
PUBLIC_NETSTAMP_TRACKING_CONSENT_COUNTRIES=
