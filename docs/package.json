{
	"name": "@netstamp/docs",
	"private": true,
	"type": "module",
	"scripts": {
		"astro": "astro",
		"build": "pnpm -C .. --filter @netstamp/i18n build && pnpm -C .. --filter @netstamp/ui build && pnpm -C .. --filter @netstamp/ui build:storybook -o ../../docs/public/storybook && astro build",
		"predev": "pnpm -C .. --filter @netstamp/i18n build && pnpm -C .. --filter @netstamp/ui build",
		"dev": "astro dev",
		"preview": "astro preview"
	},
	"dependencies": {
		"@astrojs/markdown-remark": "^7.2.0",
		"@astrojs/mdx": "^7.0.0",
		"@astrojs/react": "^6.0.0",
		"@netstamp/brand": "workspace:*",
		"@netstamp/i18n": "workspace:*",
		"@netstamp/ui": "workspace:*",
		"@phosphor-icons/webcomponents": "^2.1.5",
		"@scalar/astro": "^0.4.5",
		"astro": "^7.0.2",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"remark-directive": "^4.0.0",
		"three": "^0.185.1"
	},
	"devDependencies": {
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3"
	}
}
