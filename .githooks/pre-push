#!/bin/sh

set -eu

hook_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
refs_file=$(mktemp "${TMPDIR:-/tmp}/netstamp-pre-push.XXXXXX")

cleanup() {
	rm -f "$refs_file"
}
trap cleanup EXIT HUP INT TERM

cat >"$refs_file"

"$hook_dir/pre-push-backend.sh" "$refs_file"
"$hook_dir/pre-push-frontend.sh" "$refs_file"
