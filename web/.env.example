# Browser API base URL. Keep this as /api/v1 in local dev so Vite can proxy
# requests to the backend without browser CORS or cookie-domain issues.
VITE_NETSTAMP_API_BASE_URL=/api/v1

# Vite dev-server proxy target for /api/* requests.
VITE_NETSTAMP_API_PROXY_TARGET=http://localhost:8080

# Build-time access controls for demo deployments. The backend must also set
# the matching runtime env vars for enforcement.
VITE_NETSTAMP_REGISTRATION_ENABLED=true
VITE_NETSTAMP_PROJECT_CREATION_ENABLED=true
VITE_NETSTAMP_USER_CREDENTIAL_CHANGES_ENABLED=true
VITE_NETSTAMP_DEMO_MODE=false
VITE_NETSTAMP_DEMO_EMAIL=
VITE_NETSTAMP_DEMO_PASSWORD=

# Optional public tracker IDs. Leave blank to disable each tracker.
VITE_NETSTAMP_GA_MEASUREMENT_ID=
VITE_NETSTAMP_GOOGLE_TAG_ID=
VITE_NETSTAMP_CLARITY_PROJECT_ID=
VITE_NETSTAMP_META_PIXEL_ID=
# Optional alias for Meta Pixel if an existing deployment already uses Facebook naming.
VITE_NETSTAMP_FACEBOOK_PIXEL_ID=
VITE_NETSTAMP_POSTHOG_KEY=
VITE_NETSTAMP_POSTHOG_HOST=https://us.i.posthog.com
VITE_NETSTAMP_PLAUSIBLE_DOMAIN=
VITE_NETSTAMP_PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js
VITE_NETSTAMP_UMAMI_WEBSITE_ID=
VITE_NETSTAMP_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js

# Consent modes:
# - regional: ask only in configured countries, and ask when country is unknown.
# - always: ask every visitor before loading trackers.
# - never: load configured trackers without showing this banner.
VITE_NETSTAMP_TRACKING_CONSENT_MODE=regional
VITE_NETSTAMP_TRACKING_CONSENT_COUNTRIES=
