{
	"name": "@netstamp/web",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"prebuild": "pnpm --filter @netstamp/i18n build && pnpm --filter @netstamp/ui build",
		"build": "vite build",
		"predev": "pnpm --filter @netstamp/i18n build && pnpm --filter @netstamp/ui build",
		"dev": "vite",
		"generate:api-types": "openapi-typescript ../docs/public/openapi.json -o src/shared/api/openapi.d.ts",
		"lint": "eslint .",
		"preview": "vite preview",
		"test": "vitest run",
		"pretypecheck": "pnpm --filter @netstamp/i18n build && pnpm --filter @netstamp/ui build",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@netstamp/brand": "workspace:*",
		"@netstamp/i18n": "workspace:*",
		"@netstamp/ui": "workspace:*",
		"@phosphor-icons/react": "^2.1.10",
		"@tanstack/react-query": "^5.101.1",
		"echarts": "^6.1.0",
		"i18next": "^26.3.6",
		"maplibre-gl": "^5.24.0",
		"openapi-fetch": "^0.17.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-helmet-async": "^3.0.0",
		"react-i18next": "^17.0.10",
		"react-router-dom": "^7.18.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"eslint": "^10.5.0",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.5.3",
		"globals": "^17.7.0",
		"jiti": "^2.7.0",
		"jsdom": "^29.1.1",
		"openapi-typescript": "^7.13.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0",
		"vite": "^8.1.0",
		"vitest": "^4.1.10"
	}
}
