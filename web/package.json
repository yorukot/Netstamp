{
	"name": "@netstamp/web",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"prebuild": "pnpm --filter @netstamp/ui build",
		"build": "vite build",
		"predev": "pnpm --filter @netstamp/ui build",
