APP_ENV=local
DEMO_MODE=false
SERVICE_NAME=controller
APP_VERSION=0.0.0
API_VERSION=v1
LOG_LEVEL=debug
LOG_PSEUDONYM_KEY=local-development-log-pseudonym-key-change-before-production

BACKEND_BASE_URL=
PUBLIC_WEB_BASE_URL=
HTTP_ADDR=:8080
REQUEST_TIMEOUT=10s
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_TRUSTED_PROXIES=
SHUTDOWN_TIMEOUT=10s

# Optional. Set this to a built web/dist directory to let the controller serve the frontend.
# WEB_DIR=

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=netstamp
DATABASE_PASSWORD=netstamp
DATABASE_NAME=netstamp
DATABASE_SSLMODE=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=0
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m

AUTH_JWT_SECRET=local-development-jwt-secret-change-before-production
AUTH_ACCESS_TOKEN_TTL=12h
AUTH_REGISTRATION_ENABLED=true
AUTH_PASSWORD_RESET_TOKEN_TTL=30m
AUTH_PASSWORD_RESET_RATE_LIMIT_WINDOW=1h
AUTH_PASSWORD_RESET_IP_LIMIT=10
AUTH_PASSWORD_RESET_EMAIL_LIMIT=3
AUTH_ARGON2ID_MEMORY_KIB=65536
AUTH_ARGON2ID_ITERATIONS=3
AUTH_ARGON2ID_PARALLELISM=4

ALERT_EVALUATION_ENABLED=true
NOTIFICATION_WORKER_ENABLED=true
NOTIFICATION_WORKER_INTERVAL=5s
NOTIFICATION_WORKER_BATCH_SIZE=25
NOTIFICATION_WORKER_STALE_TIMEOUT=1m
NOTIFICATION_HTTP_TIMEOUT=10s
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS_MODE=starttls
SMTP_TIMEOUT=10s

OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:10428/insert/opentelemetry/v1/traces
